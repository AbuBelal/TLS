@using TLSWeb.Components
@attribute [Route(PagesUris.CenterPages.DailyReport)]

<h3>
    <i class="bi bi-table me-2 text-primary"></i>
تقرير حضور الطلاب اليومي</h3>

@if(DailyReports is null || DailyReports.Count<=0)
{
    <LoadingComponent></LoadingComponent>
}
else
{
    @* @model List<DailyReport> *@

<div class="container mt-4">
    <h2 class="mb-4">تقرير الحضور اليومي للمراكز</h2>

    <div class="row bg-dark text-white p-2 d-none d-md-flex fw-bold">
        <div class="col-md-3">اسم المركز</div>
        <div class="col-md-9 text-center">بيانات الطلاب (مسجلين / حضور)</div>
    </div>

    @foreach (var item in DailyReports)
    {
        <div class="row border-bottom align-items-center py-3">
            <div class="col-md-3 fw-bold text-primary">
                @item.Center?.Name 
                <div class="text-muted small">@item.ReportDate.ToString("yyyy-MM-dd")</div>
            </div>

            <div class="col-md-9">
                
                <div class="row mb-2 bg-light p-2 rounded">
                    <div class="col-12 small text-muted border-bottom mb-1">إجمالي المسجلين: <strong>@item.RegTotal</strong></div>
                    @for (int i = 1; i <= 9; i++)
                    {
                        var regValue = item.GetType().GetProperty($"RegStd0{i}")?.GetValue(item, null);
                        <div class="col">
                            <span class="d-block x-small text-secondary">فئة @i</span>
                            <span class="badge bg-info text-dark">@regValue</span>
                        </div>
                    }
                </div>

                <div class="row p-2">
                    <div class="col-12 small text-muted border-bottom mb-1">تسجيل الحضور اليومي:</div>
                    @for (int i = 1; i <= 9; i++)
                    {
                        <div class="col">
                            <label class="d-block x-small">فئة @i</label>
                            <input type="number" 
                                       name="Reports[@DailyReports.IndexOf(item)].AttStd0@i"
                                   value="@item.GetType().GetProperty($"AttStd0{i}")?.GetValue(item, null)" 
                                   class="form-control form-control-sm shadow-sm" 
                                   min="0" />
                        </div>
                    }
                </div>

            </div>
        </div>
    }
    
    <div class="mt-4">
        <button type="submit" class="btn btn-success px-5">حفظ التقارير</button>
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
    .form-control-sm { padding: 0.25rem; font-size: 0.8rem; }
</style>
}

@code {
    List<SharedLib.Entities.DailyReport> DailyReports = new();

    protected override async Task OnInitializedAsync()
    {
        DailyReports =await DailyReportApi.GetDailyReport();
    }

}
