<AuthorizeView>
    <Authorized>
        <span>أهلاً، @context.User.Identity?.Name</span>
        <form action="auth/logout" method="post" style="display:inline">
            <AntiforgeryToken />
            <button type="submit" class="btn btn-link">خروج</button>
        </form>
    </Authorized>
    <NotAuthorized>
        <a href="login">تسجيل الدخول</a>
    </NotAuthorized>
</AuthorizeView>