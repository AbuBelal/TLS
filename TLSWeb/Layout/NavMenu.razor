                        </a>
                        <a href="@PagesUris.UsersPages.Add" class="@SubLinkClass" @onclick="CloseSidebar">
                            <span class="w-1.5 h-1.5 rounded-full bg-white/35 flex-shrink-0"></span>
                            <span>إضافة مستخدم</span>
                        </a>
