                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>عرض الثوابت</span>
                </a>
                <a class="text-white/60 hover:text-white py-2 text-xs transition-colors flex items-center gap-2" href="@PagesUris.LookupsValuePages.Add">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>إضافة ثابت</span>
                </a>
            </div>
        </div>
        <!-- Reports (Collapsible) -->
        <div class="menu-item">
            <button class="w-[calc(100%-1rem)] text-white/80 hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/10 hover:scale-[1.01] rounded-xl text-right" onclick="this.parentElement.classList.toggle('active')">
                <span class="material-symbols-outlined" data-icon="analytics">analytics</span>
                <span class="flex-1">التقارير</span>
                <span class="material-symbols-outlined text-sm chevron-icon" data-icon="expand_more">expand_more</span>
            </button>
            <div class="menu-content pr-12 flex flex-col gap-1 mt-1">
                <a class="text-white/60 hover:text-white py-2 text-xs transition-colors flex items-center gap-2" href="#">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>تقارير الأداء</span>
                </a>
                <a class="text-white/60 hover:text-white py-2 text-xs transition-colors flex items-center gap-2" href="#">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>الإحصائيات السنوية</span>
                </a>
            </div>
        </div>
        <!-- Settings (Collapsible) -->
        <div class="menu-item">
            <button class="w-[calc(100%-1rem)] text-white/80 hover:text-white mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:bg-white/10 hover:scale-[1.01] rounded-xl text-right" onclick="this.parentElement.classList.toggle('active')">
                <span class="material-symbols-outlined" data-icon="settings">settings</span>
                <span class="flex-1">الإعدادات</span>
                <span class="material-symbols-outlined text-sm chevron-icon" data-icon="expand_more">expand_more</span>
            </button>
            <div class="menu-content pr-12 flex flex-col gap-1 mt-1">
                <a class="text-white/60 hover:text-white py-2 text-xs transition-colors flex items-center gap-2" href="#">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>إعدادات النظام</span>
                </a>
                <a class="text-white/60 hover:text-white py-2 text-xs transition-colors flex items-center gap-2" href="#">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
                    <span>إدارة الصلاحيات</span>
                </a>
            </div>
        </div>
    </nav>
    <div class="mt-auto px-2 space-y-1">
        <button class="w-full flex items-center gap-3 bg-white/10 hover:bg-white/20 text-white rounded-xl px-4 py-3 transition-all mb-4 active:scale-95">
            <span class="material-symbols-outlined" data-icon="add_circle">add_circle</span>
            <span>إضافة سجل جديد</span>
        </button>
        <a class="flex items-center gap-3 text-white/70 hover:text-white px-4 py-2 mx-2 transition-colors hover:bg-white/10 rounded-lg" href="#">
            <span class="material-symbols-outlined" data-icon="help">help</span>
            <span>المساعدة</span>
        </a>
        <a class="flex items-center gap-3 text-white/70 hover:text-white px-4 py-2 mx-2 transition-colors hover:bg-white/10 rounded-lg" href="#">
            <span class="material-symbols-outlined" data-icon="logout">logout</span>
            <span>تسجيل الخروج</span>
        </a>
    </div>
</aside>





