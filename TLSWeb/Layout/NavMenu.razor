                <span class="flex-1 text-right">الثوابت</span>
                <span class="material-symbols-outlined @ChevronClass("lookups")" style="font-size:18px">
                    expand_more
                </span>
            </button>
            @if (openGroup == "lookups")
            {
                <div class="pr-10 mt-0.5 space-y-0.5" style="animation: slideDown 0.2s ease">
                    <a href="@PagesUris.LookupsValuePages.Manage" class="@SubLinkClass" @onclick="CloseSidebar">
                        <span class="w-1.5 h-1.5 rounded-full bg-white/35 flex-shrink-0"></span>
                        <span>عرض الثوابت</span>
                    </a>
                    <a href="@PagesUris.LookupsValuePages.Add" class="@SubLinkClass" @onclick="CloseSidebar">
                        <span class="w-1.5 h-1.5 rounded-full bg-white/35 flex-shrink-0"></span>
