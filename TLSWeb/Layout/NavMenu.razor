<aside class="bg-[#009EDB] dark:bg-[#00658e] font-['IBM_Plex_Sans_Arabic'] text-sm font-medium leading-relaxed tracking-wide fixed top-0 right-0 h-full w-auto flex flex-col z-40 shadow-[-12px_0_32px_rgba(25,28,30,0.06)] py-6 rtl">
    <div class="px-6 mb-8">
