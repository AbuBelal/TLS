       </AuthorizeView>
    </nav>

    @* ── Footer القائمة ── *@
    <div class="mt-auto px-2 pb-4 pt-2 border-t border-white/10 space-y-0.5 flex-shrink-0">
        @* <a href="#"
           class="flex items-center gap-3 text-white/65 hover:text-white px-3 py-2.5
                  rounded-xl hover:bg-white/12 transition-colors text-sm">
            <span class="material-symbols-outlined" style="font-size:18px">help</span>
            <span>المساعدة</span>
        </a> *@
        <a href="#" onclick="@(async ()=> { var customAuthStateProvider = (CookieAuthenticationStateProvider)authenticationStateProvider; await customAuthStateProvider.LogoutAsync();})"
           class="flex items-center gap-3 text-white/65 hover:text-white px-3 py-2.5
                  rounded-xl hover:bg-white/12 transition-colors text-sm">
            <span class="material-symbols-outlined" style="font-size:18px">logout</span>
            <span>تسجيل الخروج</span>
        </a>
    </div>

</aside>

@* ══ CSS Animations — داخل style tag مباشرةً لأن Tailwind لا يدعمها ══ *@
<style>
    @@keyframes fadeIn   { from { opacity: 0 } to { opacity: 1 } }
    @@keyframes slideDown { from { opacity:0; transform:translateY(-6px) } to { opacity:1; transform:translateY(0) } }
</style>

@code {
    private bool   IsOpen    = false;
    private string openGroup = string.Empty;
    private string CurrentUrl = string.Empty;

    // ── Sidebar classes — تتغير بين Desktop (sticky) والجوال (fixed drawer) ──
    private string SidebarClasses =>
        "bg-[#009EDB] flex flex-col " +
        "font-['IBM_Plex_Sans_Arabic'] text-sm font-medium " +
        // Desktop (>= lg): sticky تأخذ مكانها الطبيعي في اللياوت ولا تغطي المحتوى
        "lg:sticky lg:top-0 lg:h-screen lg:w-64 lg:flex-shrink-0 lg:z-50 " +
        // Mobile (< lg): fixed drawer ينزلق من اليمين
        "fixed top-0 right-0 h-full w-64 z-[300] " +
        "transition-transform duration-300 ease-in-out " +
        (IsOpen ? "translate-x-0 shadow-2xl" : "translate-x-full lg:translate-x-0");

    // ── Classes رابط مفرد ──
    private string NavLinkClass(string href)
    {
        var isActive = CurrentUrl == href || (href == "/" && CurrentUrl == "/");
        return "flex items-center gap-3 px-3 py-2.5 rounded-xl transition-all duration-200 " +
               "text-sm font-medium " +
               (isActive
                   ? "bg-white/20 text-white"
                   : "text-white/80 hover:text-white hover:bg-white/12");
    }

    // ── Classes زر المجموعة ──
    private string GroupBtnClass(string group)
    {
        var isOpen = openGroup == group;
        return "w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium " +
               "transition-all duration-200 " +
               (isOpen
                   ? "bg-white/15 text-white"
                   : "text-white/80 hover:text-white hover:bg-white/12");
    }

    // ── Classes سهم التوسيع ──
    private string ChevronClass(string group) =>
        "transition-transform duration-200 text-white/50 " +
        (openGroup == group ? "rotate-180 !text-white" : "");

    // ── Classes الروابط الفرعية ──
    private const string SubLinkClass =
        "flex items-center gap-2 py-2 px-2.5 rounded-lg text-xs " +
        "text-white/60 hover:text-white hover:bg-white/10 transition-colors";

    protected override void OnInitialized()
    {
        CurrentUrl = "/" + NavManager.ToBaseRelativePath(NavManager.Uri);
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CurrentUrl = "/" + NavManager.ToBaseRelativePath(e.Location);
        IsOpen     = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar() => IsOpen = !IsOpen;
    private void CloseSidebar()  => IsOpen = false;

    private void ToggleGroup(string group)
        => openGroup = (openGroup == group) ? string.Empty : group;

    public void Dispose()
        => NavManager.LocationChanged -= OnLocationChanged;
}
