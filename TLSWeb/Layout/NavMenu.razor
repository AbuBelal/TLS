@* ╔══════════════════════════════════════════════════════════════╗ *@
@* ║  TLSWeb/Layout/NavMenu.razor  — Responsive                  ║ *@
@* ║  يعتمد على Tailwind (كما في المشروع الأصلي)                 ║ *@
@* ║  + material-symbols-outlined للأيقونات                      ║ *@
@* ╚══════════════════════════════════════════════════════════════╝ *@

@implements IDisposable

@* ══ زر Hamburger — يظهر فقط على الجوال ══ *@
<button id="hamburger-btn"
        class="fixed top-3 right-3 z-[400] flex items-center justify-center w-10 h-10
               bg-white rounded-xl shadow-md border border-gray-200
               lg:hidden transition-all duration-200 hover:bg-gray-50"
        @onclick="ToggleSidebar"
        aria-label="فتح القائمة">
    <span class="material-symbols-outlined text-[#009EDB]" style="font-size:22px">
        @(IsOpen ? "close" : "menu")
    </span>
</button>

@* ══ Overlay ══ *@
@if (IsOpen)
{
    <div class="fixed inset-0 bg-black/50 z-[290] lg:hidden"
         @onclick="CloseSidebar"
         style="animation: fadeIn 0.2s ease">
    </div>
}

@* ══ القائمة الجانبية ══ *@
<aside class="@SidebarClasses" dir="rtl">

    @* ── الشعار ── *@
    <div class="flex items-center gap-3 px-4 py-5 border-b border-white/10 flex-shrink-0">
        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-content-center flex-shrink-0"
             style="display:flex;align-items:center;justify-content:center">
            <span class="material-symbols-outlined text-white" style="font-size:22px">school</span>
        </div>
        <div class="flex-1 min-w-0">
            <h1 class="text-sm font-bold text-white font-['Tajawal'] leading-tight truncate">
                مساحات التعليم المؤقتة
            </h1>
            <p class="text-white/55 text-[10px] leading-tight mt-0.5">جباليا</p>
        </div>
        @* زر الإغلاق — جوال فقط *@
        <button class="lg:hidden flex items-center justify-center w-7 h-7 rounded-lg
                       text-white/60 hover:text-white hover:bg-white/15 transition-colors"
                @onclick="CloseSidebar">
            <span class="material-symbols-outlined" style="font-size:18px">close</span>
        </button>
    </div>

    @* ── منطقة التنقل ── *@
    <nav class="flex-1 overflow-y-auto py-3 px-2 space-y-0.5"
         style="scrollbar-width:thin; scrollbar-color:rgba(255,255,255,.2) transparent">

        @* الرئيسية *@
        <a href="/"
           class="@NavLinkClass(PagesUris.Home)" 
           @onclick="CloseSidebar"
           @onclick:preventDefault="false">
            <span class="material-symbols-outlined" style="font-size:20px">dashboard</span>
            <span class="flex-1">الرئيسية</span>
        </a>

        @* @* لوحة المدير — للمدير فقط *@
        @* <AuthorizeView Roles="@Roles.Admin"> 
            <a href="/"
               class="@NavLinkClass("/")"
               @onclick="CloseSidebar"
               @onclick:preventDefault="false">
                <span class="material-symbols-outlined" style="font-size:20px">admin_panel_settings</span>
                <span class="flex-1">لوحة التحكم </span>
            </a>
         </AuthorizeView> *@ 

        <AuthorizeView Roles="@Roles.User"> 
        <a href="/Center/Edit"
       class="@NavLinkClass(PagesUris.CenterPages.Edit)"
       @onclick="CloseSidebar"
       @onclick:preventDefault="false">
        <span class="material-symbols-outlined" style="font-size:20px">edit_square</span>
        <span class="flex-1">بيانات مركزي</span>
    </a>
        </AuthorizeView>
        @* الطلاب *@
        <div>
            <button class="@GroupBtnClass("students")"
                    @onclick='() => ToggleGroup("students")'>
                <span class="material-symbols-outlined" style="font-size:20px">school</span>
                <span class="flex-1 text-right">الطلاب</span>
                <span class="material-symbols-outlined @ChevronClass("students")" style="font-size:18px">
                    expand_more
                </span>
            </button>
            @if (openGroup == "students")
            {
                <div class="pr-10 mt-0.5 space-y-0.5" style="animation: slideDown 0.2s ease">
                    <a href="@PagesUris.StudentsPages.Manage" class="@SubLinkClass" @onclick="CloseSidebar">
                        <span class="w-1.5 h-1.5 rounded-full bg-white/35 flex-shrink-0"></span>
                        <span>عرض جميع الطلاب</span>
                    </a>
                    <a href="@PagesUris.StudentsPages.Add" class="@SubLinkClass" @onclick="CloseSidebar">
                        <span class="w-1.5 h-1.5 rounded-full bg-white/35 flex-shrink-0"></span>
                        <span>إضافة طالب جديد</span>
                    </a>
                </div>
            }
        </div>

        @* الموظفون *@
        <div>
            <button class="@GroupBtnClass("staff")"
                    @onclick='() => ToggleGroup("staff")'>
                <span class="material-symbols-outlined" style="font-size:20px">badge</span>
                <span class="flex-1 text-right">الموظفون</span>
                <span class="material-symbols-outlined @ChevronClass("staff")" style="font-size:18px">
