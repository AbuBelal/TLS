    <nav class="flex-1 space-y-2 overflow-y-auto custom-scrollbar">
        <!-- Dashboard (Active) -->
        <div class="menu-item">
            <a class="bg-white/15 text-white rounded-full mx-2 px-4 py-3 flex items-center gap-3 transition-all duration-300 hover:scale-[1.01]" href="/">
