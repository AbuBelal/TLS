@using TLSWeb.Pages.Students.Components
@attribute [Route(PagesUris.StudentsPages.Manage)]
<EmisInfo />
<div class="container-fluid px-4">
    @* ===== العنوان ===== *@
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="mb-0">
            <i class="bi bi-people-fill me-2 text-primary"></i>إدارة الطلاب
        </h3>
        @* <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
            <i class="bi bi-plus-circle me-1"></i> إضافة طالب جديد
        </button> *@
        @* ── أزرار الإجراءات ── *@
        <div class="d-flex gap-2" dir="rtl">

            @* زر إضافة طالب *@
            <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
                <i class="bi bi-plus-circle me-1"></i>إضافة طالب جديد
            </button>

            @* ── زر التصدير مع Dropdown ── *@
            <div class="position-relative" @onclick:stopPropagation="true">
                <button class="btn btn-success shadow-sm d-flex align-items-center gap-2"
                        @onclick="ToggleExportMenu"
                        disabled="@(isExportingFiltered || isExportingAll)">
                    @if (isExportingFiltered || isExportingAll)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>جاري التصدير...</span>
                    }
                    else
                    {
                        <i class="bi bi-file-earmark-excel-fill"></i>
                        <span>تصدير Excel</span>
                        <i class="bi bi-chevron-down" style="font-size:.75rem"></i>
                    }
                </button>

                @* Dropdown القائمة *@
                @if (showExportMenu)
                {
                    <div class="position-absolute bg-white border rounded-3 shadow-lg p-1"
                         style="top:calc(100% + 6px);left:0;min-width:280px;z-index:200">

                        @* الخيار 1: تصدير المعروض *@
                        <button class="btn btn-light w-100 text-end d-flex align-items-start gap-3 p-3 rounded-2 mb-1 border-0"
                                style="transition:background .15s"
                                @onclick="ExportFiltered"
                                disabled="@isExportingFiltered">

                            <div class="rounded-2 p-2 bg-success bg-opacity-10 flex-shrink-0">
                                <i class="bi bi-funnel-fill text-success fs-5"></i>
                            </div>
                            <div class="text-end">
                                <div class="fw-semibold small">تصدير المعروض حسب التصفية</div>
                                <div class="text-muted" style="font-size:.72rem">
                                    @totalCount طالب — @FilterDescription
                                </div>
                            </div>
                        </button>

                        <hr class="my-1" />

                        @* الخيار 2: تصدير الكل *@
                        <button class="btn btn-light w-100 text-end d-flex align-items-start gap-3 p-3 rounded-2 border-0"
                                style="transition:background .15s"
                                @onclick="ExportAll"
                                disabled="@isExportingAll">

                            <div class="rounded-2 p-2 bg-primary bg-opacity-10 flex-shrink-0">
                                <i class="bi bi-people-fill text-primary fs-5"></i>
                            </div>
                            <div class="text-end">
                                <div class="fw-semibold small">تصدير جميع طلاب المركز</div>
                                <div class="text-muted" style="font-size:.72rem">
                                    بدون فلاتر — مرتّب حسب المستوى والاسم
                                </div>
                            </div>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ===== شريط البحث والفلاتر ===== *@
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted small">
                        <i class="bi bi-search me-1"></i> بحث بالاسم أو رقم الهوية
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text"
                               class="form-control border-start-1"
                               placeholder="ابحث هنا..."
                               @bind="searchText"
                               @bind:event="oninput"
                               @bind:after="OnFilterChanged" />
                    </div>
                </div>
                <div class="col-md-1">
                    <label class="form-label fw-semibold text-muted small">
                        <i class="bi bi-gender-ambiguous me-1"></i> الجنس
                    </label>
                    <select class="form-select"
                            @bind="selectedGender"
                            @bind:after="OnFilterChanged">
                        <option value="">الكل</option>
                        @foreach (var gender in genderOptions)
                        {
                            <option value="@gender">@gender</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold text-muted small">
                        <i class="bi bi-bar-chart-steps me-1"></i> المستوى
                    </label>
                    <select class="form-select"
                            @bind="selectedLevel"
                            @bind:after="OnFilterChanged">
                        <option value="">— الكل —</option>
                        @foreach (var level in levelOptions)
                        {
                            <option value="@level">@level</option>
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label">الشعبة</label>
                    <InputNumber @bind-Value="SelectedSection" class="form-control" min="0"
                                 @onfocusout="OnFilterChanged" />
                </div>
                
                <AuthorizeView Roles=@SharedLib.Fixed.Roles.Admin>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold text-muted small">
                            <i class="bi bi-bar-chart-steps me-1"></i> المركز
                        </label>
                        <select class="form-select"
                                @bind="selectedCenter"
                                @bind:after="OnFilterChanged">
                            <option value="">— الكل —</option>
                            @foreach (var Center in CenterOptions)
                            {
                                <option value="@Center">@Center</option>
                            }
                        </select>
                    </div>
                </AuthorizeView>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100"
                            @onclick="ResetFilters">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> إعادة تعيين
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ===== عدد النتائج وحجم الصفحة ===== *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6">
                <i class="bi bi-hash me-1"></i>
                عدد النتائج: <strong>@totalCount</strong> طالب
            </span>
           @*  <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
                <i class="bi bi-server me-1"></i> Server-Side
            </span> *@
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">عرض:</span>
            <select class="form-select form-select-sm" style="width:75px;"
                    @bind="pageSize" @bind:after="OnPageSizeChanged">
                <option value="5">5</option>
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
            </select>
            <span class="text-muted small">لكل صفحة</span>
        </div>
    </div>

    @* ===== Loading / Empty / Table ===== *@
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">جاري تحميل البيانات من الخادم...</p>
        </div>
    }
    else if (!students.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox display-4 d-block mb-2"></i>
            <p class="fs-6">لا توجد بيانات للعرض</p>
            <p class="small">جرب تغيير معايير البحث أو التصفية</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:50px">#</th>
                            <th><i class="bi bi-person me-1"></i>الاسم</th>
                            <th><i class="bi bi-card-text me-1"></i>رقم الهوية</th>
                            <th><i class="bi bi-phone me-1"></i>الجوال</th>
                            <th>الجنس</th>
                            <th><i class="bi bi-mortarboard me-1"></i>المستوى</th>
                            <th><i class="bi bi-mortarboard me-1"></i>المركز</th>
                            <th class="text-center" style="width:160px">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 0;
                        }
                        @foreach (var student in students)
                        {
                            rowIndex++;
                            <tr>
                                <td class="text-muted small">
                                    @((currentPage - 1) * pageSize + rowIndex)
                                </td>
                                <td>
                                    <div class="fw-semibold">@student.Name</div>
                                    <small class="text-muted">@student.EnName</small>
                                </td>
                                <td>
                                    <code class="bg-light px-2 py-1 rounded">
                                        @student.CivilId
                                    </code>
                                </td>
                                <td class="text-muted small font-monospace">
                                    @student.Mobile
                                </td>
                                <td>
                                    @if (student.GenderName == "ذكر")
                                    {
                                        <span class="badge bg-primary bg-opacity-10
                                            text-primary border border-primary
                                            border-opacity-25">
                                            <i class="bi bi-gender-male me-1"></i>ذكر
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10
                                            text-danger border border-danger
                                            border-opacity-25">
                                            <i class="bi bi-gender-female me-1"></i>أنثى
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10
                                        text-success border border-success
                                        border-opacity-25">
                                        @* <i class="bi bi-mortarboard me-1"></i> *@
                                        @student.LevelName - @student.Section
                                    </span>
                                </td>
                                <td>
                                    @* <span class="badge bg-success bg-opacity-10
                                        text-success border border-success
                                        border-opacity-25">
                                        <i class="bi bi-mortarboard me-1"></i> *@
                                        @student.CenterName
                                    @* </span> *@
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary"
                                                @onclick="@(() => OpenEditModal(student.Id))">
                                            <i class="bi bi-pencil-square me-1"></i>
                                            تعديل
                                        </button>
                                        <button class="btn btn-outline-danger"
                                                @onclick="@(() => ConfirmDelete(student))">
                                            <i class="bi bi-trash3 me-1"></i>
                                            حذف
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* ===== Pagination ===== *@
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="text-muted small">
                    عرض @(Math.Min((currentPage - 1) * pageSize + 1, totalCount))
                    - @(Math.Min(currentPage * pageSize, totalCount))
                    من أصل <strong class="text-primary">@totalCount</strong>
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="@(() => GoToPage(1))">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </li>
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="@(() => GoToPage(currentPage - 1))">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                        @foreach (var p in GetPageNumbers())
                        {
                            <li class="page-item @(p == currentPage ? "active" : "")">
                                <button class="page-link"
                                        @onclick="@(() => GoToPage(p))">
                                    @p
                                </button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="@(() => GoToPage(currentPage + 1))">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link"
                                    @onclick="@(() => GoToPage(totalPages))">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@* ===== Delete Modal ===== *@
@if (showDeleteModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>تأكيد الحذف
                    </h5>
                    <button class="btn-close btn-close-white"
                            @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-trash3 display-4 text-danger d-block mb-3"></i>
                    <p>هل أنت متأكد من حذف الطالب</p>
                    <p class="fw-bold text-danger fs-5">
                        "@studentToDelete?.Name"
                    </p>
                    <p class="small text-muted">
                        لا يمكن التراجع عن هذا الإجراء
                    </p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button class="btn btn-secondary"
                            @onclick="CancelDelete"
                            disabled="@isDeleting">
                        <i class="bi bi-x-lg me-1"></i> إلغاء
                    </button>
                    <button class="btn btn-danger"
                            @onclick="DeleteConfirmed"
                            disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>جاري الحذف...</span>
                        }
                        else
                        {
                            <i class="bi bi-trash3 me-1"></i>
                            <span>نعم، احذف</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}






