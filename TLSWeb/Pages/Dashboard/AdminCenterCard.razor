<div class="col-12 col-lg-6">
    <div class="card border-0 shadow-sm h-100 @(isSelected ? "border border-primary" : "")"
         style="cursor:pointer"
         @onclick="() => SelectCenter(center.CenterId)">

        @* رأس البطاقة *@
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-building-fill text-primary fs-5"></i>
                <div>
                    <div class="fw-bold">@center.CenterName</div>
                    <small class="text-muted">
                        <i class="bi bi-upc me-1"></i>@center.CenterCode
                        &nbsp;|&nbsp;
                        <i class="bi bi-geo-alt me-1"></i>@center.Address
                    </small>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap justify-content-end">
                <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-1 rounded-pill">
                    <i class="bi bi-calendar-week me-1"></i>@center.DaysOfWeek
                </span>
                <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:.45rem"></i>نشط
                </span>
            </div>
        </div>

        <div class="card-body">

            @* أرقام الطلاب *@
            <div class="row g-2 mb-3">
                <div class="col-4">
                    <div class="card border-0 h-100 bg-primary bg-opacity-10">
                        <div class="card-body p-2 text-center">
                            <div class="fs-4 fw-bold text-primary">@center.TotalStudents</div>
                            <div class="text-muted small">إجمالي الطلاب</div>
                            @if (center.NewStudentsThisMonth > 0)
                            {
                                <div class="text-success" style="font-size:.7rem">
                                    <i class="bi bi-arrow-up"></i> @center.NewStudentsThisMonth جديد
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 h-100 bg-primary bg-opacity-10">
                        <div class="card-body p-2 text-center">
                            <div class="fs-4 fw-bold text-primary">@center.MaleStudents</div>
                            <div class="text-muted small">ذكور</div>
                            <div class="small text-primary" style="font-size:.7rem">@center.MalePercent%</div>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 h-100 bg-danger bg-opacity-10">
                        <div class="card-body p-2 text-center">
                            <div class="fs-4 fw-bold text-danger">@center.FemaleStudents</div>
                            <div class="text-muted small">إناث</div>
                            <div class="small text-danger" style="font-size:.7rem">@center.FemalePercent%</div>
                        </div>
                    </div>
                </div>
            </div>

            @* شريط الجنس *@
            <div class="progress mb-3" style="height:10px;border-radius:5px">
                @if (center.MalePercent > 0)
                {
                    <div class="progress-bar bg-primary" style="width:@center.MalePercent%"></div>
                }
                @if (center.FemalePercent > 0)
                {
                    <div class="progress-bar bg-danger" style="width:@center.FemalePercent%"></div>
                }
            </div>

            @* الموظفون *@
            <div class="d-flex justify-content-between align-items-center p-2 rounded-3 mb-3 bg-success-subtle">
                <span class="text-muted small">
                    <i class="bi bi-people-fill text-success me-1"></i>الموظفون
                </span>
                <div class="d-flex gap-3 small">
                    <span class="fw-semibold text-success">@center.TotalEmployees إجمالي</span>
                    <span class="text-primary">@center.MaleEmployees ذكر</span>
                    <span class="text-danger">@center.FemaleEmployees أنثى</span>
                </div>
            </div>

            @* توزيع المستويات — عند النقر *@
            @if (isSelected && center.LevelDistribution.Any())
            {
                <div class="border-top pt-3 mt-1">
                    <div class="fw-semibold small text-muted mb-2">
                        <i class="bi bi-bar-chart me-1 text-primary"></i>توزيع الطلاب حسب المستوى
                    </div>
                    @foreach (var level in center.LevelDistribution)
                    {
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="fw-semibold">@level.Label</small>
                                <small class="text-muted">@level.Count (@level.Percent%)</small>
                            </div>
                            <div class="progress" style="height:8px;border-radius:4px">
                                <div class="progress-bar @level.ColorClass"
                                     style="width:@level.Percent%;border-radius:4px"></div>
                            </div>
                        </div>
                    }
                </div>
            }

            @* شارات إضافية *@
            <div class="d-flex flex-wrap gap-2 mt-2">
                @if (center.SpecialNeedsCount > 0)
                {
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle">
                        <i class="bi bi-star me-1"></i>@center.SpecialNeedsCount احتياجات خاصة
                    </span>
                }
                @if (center.UnrwaCount > 0)
                {
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle">
                        <i class="bi bi-book me-1"></i>@center.UnrwaCount أنروا
                    </span>
                }
                @if (center.Rooms.GetValueOrDefault() > 0)
                {
                    <span class="badge bg-light text-secondary border">
                        <i class="bi bi-door-open me-1"></i>@center.Rooms غرفة
                    </span>
                }
                @if (center.Tarpaulins.GetValueOrDefault() > 0)
                {
                    <span class="badge bg-light text-secondary border">
                        <i class="bi bi-grid me-1"></i>@center.Tarpaulins خيمة
                    </span>
                }
            </div>

            @if (!isSelected)
            {
                <div class="text-center mt-3">
                    <small class="text-muted fst-italic">
                        <i class="bi bi-hand-index me-1"></i>انقر لعرض توزيع المستويات
                    </small>
                </div>
            }
        </div>
    </div>
</div>

 @code{
     [Parameter]
    public CenterSummaryDto center { get; set; }

    [Parameter]
    public bool isSelected { get; set; }

    [Parameter]
    public EventCallback<int> OnSelectCenter { get; set; }
    private void SelectCenter(long centerId)
    {
        // if (OnSelectCenter.HasDelegate)
        // {
        //     OnSelectCenter.InvokeAsync(centerId);
        // }
    }
   }