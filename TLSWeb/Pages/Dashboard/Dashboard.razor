<div class="container-fluid py-3 px-4" dir="rtl">

    @if (IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:60vh">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">جاري التحميل...</span>
            </div>
        </div>
    }
    else if (Stats is null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            لم يتم العثور على مركز مرتبط بحسابك.
        </div>
    }
    else
    {
        @* ── رأس الصفحة ── *@
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
            <div>
                <h4 class="mb-1 fw-bold">
                    <i class="bi bi-building me-2 text-primary"></i>
                    @Stats.CenterName
                </h4>
                <span class="text-muted small">
                    <i class="bi bi-geo-alt me-1"></i>@Stats.Address &nbsp;|&nbsp;
                    <i class="bi bi-upc me-1"></i>@Stats.CenterCode
                </span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                    <i class="bi bi-calendar-week me-1"></i>@Stats.DaysOfWeek
                </span>
                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>نشط
                </span>
            </div>
        </div>

        @* ── بطاقات الإحصائيات ── *@
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                            <i class="bi bi-mortarboard-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-primary">@Stats.TotalStudents</div>
                            <div class="text-muted small">إجمالي الطلاب</div>
                            <div class="text-success small">
                                <i class="bi bi-arrow-up"></i> @Stats.NewStudentsThisMonth جديد هذا الشهر
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 bg-success bg-opacity-10">
                            <i class="bi bi-people-fill text-success fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-success">@Stats.TotalEmployees</div>
                            <div class="text-muted small">إجمالي الموظفين</div>
                            <div class="text-muted small">
                                <i class="bi bi-check-circle"></i> موظف نشط حالياً
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                            <i class="bi bi-star-fill text-warning fs-4"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold text-warning">@Stats.SpecialNeedsCount</div>
                            <div class="text-muted small">ذوو احتياجات خاصة</div>
                            <div class="text-muted small">
                                @Stats.SpecialNeedsPercent% من الإجمالي
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-3 p-3 bg-purple bg-opacity-10"
                             style="background:rgba(139,92,246,.1)">
                            <i class="bi bi-book-fill fs-4" style="color:#7c3aed"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-bold" style="color:#7c3aed">@Stats.UnrwaCount</div>
                            <div class="text-muted small">طلاب الأنروا</div>
                            <div class="text-muted small">
                                @Stats.UnrwaPercent% من الإجمالي
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── معلومات المركز + توزيع الجنس ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom fw-semibold">
                        <i class="bi bi-building me-2 text-primary"></i>معلومات المركز
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="bi bi-door-open me-2"></i>الغرف</span>
                                <span class="fw-semibold">@Stats.Rooms غرفة</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="bi bi-tent me-2"></i>الخيام</span>
                                <span class="fw-semibold">@Stats.Tarpaulins خيمة</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="bi bi-grid me-2"></i>مساحات أخرى</span>
                                <span class="fw-semibold">@Stats.OtherSpaces</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="bi bi-calendar-week me-2"></i>أيام الدوام</span>
                                <span class="fw-semibold small">@Stats.DaysOfWeek</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom fw-semibold">
                        <i class="bi bi-pie-chart me-2 text-primary"></i>توزيع الطلاب حسب الجنس
                    </div>
                    <div class="card-body">
                        @foreach (var g in Stats.GenderDistribution)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-semibold">@g.Label</span>
                                    <span class="text-muted">@g.Count طالب (@g.Percent%)</span>
                                </div>
                                <div class="progress" style="height:12px;border-radius:6px">
                                    <div class="progress-bar @g.ColorClass"
                                         style="width:@(g.Percent)%;border-radius:6px">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── توزيع المستويات ── *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-bar-chart me-2 text-primary"></i>توزيع الطلاب حسب المستوى
            </div>
            <div class="card-body">
                <div class="row g-2 align-items-end" style="height:160px">
                    @foreach (var level in Stats.LevelDistribution.OrderBy(x=>x.Order))
                    {
                        <div class="col text-center d-flex flex-column justify-content-end align-items-center h-100">
                            <small class="text-muted mb-1">@level.Count</small>
                            <div class="rounded-top @level.ColorClass w-100"
                                 style="height:@(level.Percent * 1.4)px;min-height:8px;transition:height .4s">
                            </div>
                            <small class="mt-1 fw-semibold">@level.Label</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── الموظفون وأحدث الطلاب ── *@
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom fw-semibold d-flex justify-content-between">
                        <span><i class="bi bi-people me-2 text-success"></i>موظفو المركز</span>
                        <span class="badge bg-success-subtle text-success">@Stats.Employees.Count()</span>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var emp in Stats.Employees)
                            {
                                <li class="list-group-item d-flex align-items-center gap-3 py-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                    style="width:40px;height:40px;min-width:40px;
                                        background:@(emp.Gender == "أنثى" ? "#ec4899" : "#3b82f6")">
                                        @emp.Name.Substring(0, 1)
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small">@emp.Name</div>
                                        <div class="text-muted" style="font-size:.75rem">@emp.Job • @emp.Specialization</div>
                                    </div>
                                    <span class="badge bg-light text-dark border">@emp.Specialization</span>
                                    <span class="badge bg-light text-dark border">@emp.EmpId</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom fw-semibold d-flex justify-content-between">
                        <span><i class="bi bi-clock-history me-2 text-primary"></i>أحدث الطلاب المسجلين</span>
                        <span class="badge bg-primary-subtle text-primary">@Stats.RecentStudents.Count</span>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var std in Stats.RecentStudents)
                            {
                                <li class="list-group-item d-flex align-items-center gap-3 py-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                         style="width:40px;height:40px;min-width:40px;
                                        background:@(std.Gender == "أنثى" ? "#ec4899" : "#3b82f6")">
                                        @std.Name.Substring(0, 1)
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold small">@std.Name</div>
                                        <div class="text-muted" style="font-size:.75rem">
                                             @std.Level
                                            @if (std.IsUnrwa)
                                            {
                                                <span class="badge bg-info-subtle text-info ms-1">أنروا</span>
                                            }
                                            @if (std.IsSpecialNeeds)
                                            {
                                                <span class="badge bg-warning-subtle text-warning ms-1">احتياجات خاصة</span>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">@std.EnrollDate.ToString("dd/MM")</small>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>




