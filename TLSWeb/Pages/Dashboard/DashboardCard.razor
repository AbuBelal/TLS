<div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/10 hover:shadow-lg transition-all group">
    <div class="flex justify-between items-start mb-4">
        <div class="p-3 @BKColor -container rounded-lg text-on-secondary-container">
            <span class="material-symbols-outlined text-2xl" data-icon="groups">@Icon</span>
        </div>
        <span class="text-secondary text-xs font-bold bg-secondary-container/30 px-2 py-1 rounded">@Message</span>
    </div>
    <h3 class="text-on-surface-variant text-sm mb-1 font-medium">@Title</h3>
    <p class="text-3xl font-bold font-headline text-on-surface">@Value</p>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public string BKColor { get; set; } = "#3bbaa5";
    [Parameter] public string Icon { get; set; } = "person";
    [Parameter] public string Message { get; set; } = " ";

    override protected void OnParametersSet()
    {
        if (Value <= 0)
        {
            BKColor = "#ff0000";
        }
        else if (Value > 100)
        {
            BKColor = "#00ff00";
        }

        
    }
}