@* ╔══════════════════════════════════════════════════════════════╗ *@
@* ║  TLSWeb/Pages/Centers/CenterEdit.razor                       ║ *@
@* ║  صفحة تعديل بيانات المركز — لمدير المركز (Role=User) فقط   ║ *@
@* ╚══════════════════════════════════════════════════════════════╝ *@

@attribute [Route(PagesUris.CenterPages.Edit)]

<div class="container-fluid px-4 border-2 " dir="rtl" style="background:@BackgroundColor">

    @* ══ رأس الصفحة ══ *@
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="mb-0">
            <i class="bi bi-building-gear me-2 text-primary"></i>تعديل بيانات المركز
        </h3>
    </div>

    @* ══ تحميل ══ *@
    @if (IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:50vh">
            <div class="text-center">
                <div class="spinner-border text-primary" style="width:3rem;height:3rem" role="status"></div>
                <p class="mt-3 text-muted small">جاري تحميل بيانات المركز...</p>
            </div>
        </div>
    }

    @* ══ خطأ ══ *@
    else if (ErrorMsg is not null)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mt-3">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span>@ErrorMsg</span>
        </div>
    }

    @* ══ النموذج ══ *@
    else
    {
        <EditForm Model="@Model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="row g-4">

                @* ── العمود الأيمن: المعلومات الأساسية ── *@
                <div class="col-lg-8">

                    @* بطاقة المعلومات الأساسية *@
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom fw-semibold py-3">
                            <i class="bi bi-info-circle me-2 text-primary"></i>المعلومات الأساسية
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                @* اسم المركز *@
                                <div class="col-md-8">
                                    <label class="form-label fw-semibold text-muted small">
                                        اسم المركز <span class="text-danger">*</span>
                                    </label>
                                    <InputText @bind-Value="Model.Name" disabled=@(!IsAdmin)
                                               class="form-control"
                                               placeholder="أدخل اسم المركز" />
                                    <ValidationMessage For="@(() => Model.Name)" class="text-danger small" />
                                </div>

                                @* كود المركز *@
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold text-muted small">
                                        كود المركز
                                    </label>
                                    <InputText @bind-Value="Model.CenterCode" disabled=@(!IsAdmin)
                                               class="form-control"
                                               placeholder="مثال: JB-001" />
                                    <ValidationMessage For="@(() => Model.CenterCode)" class="text-danger small" />
                                </div>
                                @*  اسم المركز بالانجليزية*@
                                <div class="col-md-8">
                                    <label class="form-label fw-semibold text-muted small">
                                        اسم المركز بالإنجليزية <span class="text-danger">*</span>
                                    </label>
                                    <InputText @bind-Value="Model.EnName" disabled=@(!IsAdmin)
                                               class="form-control"
                                               placeholder=" أدخل اسم المركز بالإنجليزية" />
                                    <ValidationMessage For="@(() => Model.EnName)" class="text-danger small" />
                                </div>

                                @* رقم المبنى *@
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold text-muted small">
                                        رقم المبنى
                                    </label>
                                    <InputText @bind-Value="Model.BuildingCode" disabled=@(!IsAdmin)
                                               class="form-control"
                                               placeholder="2xxxxxx" />
                                    <ValidationMessage For="@(() => Model.BuildingCode)" class="text-danger small" />
                                </div>

                                @* ترتيب العرض *@
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold text-muted small">
                                        ترتيب العرض
                                    </label>
                                    <InputNumber @bind-Value="Model.SortOrder" disabled=@(!IsAdmin)
                                               class="form-control"
                                               placeholder="01" />
                                    <ValidationMessage For="@(() => Model.SortOrder)" class="text-danger small" />
                                </div>

                                @* العنوان *@
                                <div class="col-8">
                                    <label class="form-label fw-semibold text-muted small">
                                        العنوان
                                    </label>
                                    <InputText @bind-Value="Model.Address"
                                               class="form-control"
                                               placeholder="الحي، الشارع، المنطقة" />
                                    <ValidationMessage For="@(() => Model.Address)" class="text-danger small" />
                                </div>

                                @* فترة الدوام *@
                                <div class="col-4">
                                    <label class="form-label fw-semibold text-muted small">
                                        فترة الدوام
                                    </label>
                                    @* <InputText @bind-Value="Model.Address"
                                               class="form-control"
                                               placeholder="صباحي / مسائي" /> *@
                                    <InputSelect @bind-Value="Model.WHours" class="form-select">
                                        <option value="">-- اختر فترة الدوام --</option>
                                        @foreach (var g in WHoures)
                                        {
                                            <option value="@g.Id">@g.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => Model.WHours)" class="text-danger small" />
                                </div>

                                @* ملاحظات *@
                                <div class="col-12">
                                    <label class="form-label fw-semibold text-muted small">ملاحظات</label>
                                    <InputTextArea @bind-Value="Model.Comments"
                                                  class="form-control"
                                                  rows="3"
                                                  placeholder="أي ملاحظات إضافية..." />
                                </div>

                            </div>
                        </div>
                    </div>

                    @* بطاقة أيام الدوام *@
                    <div class="card border-0 shadow-sm mb-4" >
                        <div class="card-header bg-white border-bottom fw-semibold py-3">
                            <i class="bi bi-calendar-week me-2 text-primary"></i>أيام الدوام
                            <span class="text-danger ms-1">*</span>
                        </div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var day in AllDays)
                                {
                                    var selected = IsDaySelected(day);
                                    <button type="button" disabled=@(!IsAdmin)
                                            class="btn btn-sm @(selected ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3"
                                            @onclick="() => ToggleDay(day)">
                                        @if (selected)
                                        {
                                            <i class="bi bi-check-circle-fill me-1"></i>
                                        }
                                        @day
                                    </button>
                                }
                            </div>

                            @* عرض النص المُولَّد *@
                            <div class="p-2 rounded-3 bg-primary bg-opacity-10">
                                <small class="text-muted">أيام الدوام المحددة: </small>
                                <span class="fw-semibold text-primary small">
                                    @(string.IsNullOrEmpty(Model.DaysOfWeek) ? "—" : Model.DaysOfWeek)
                                </span>
                            </div>

                            <ValidationMessage For="@(() => Model.DaysOfWeek)" class="text-danger small d-block mt-1" />
                        </div>
                    </div>

                </div>

                @* ── العمود الأيسر: المرافق ── *@
                <div class="col-lg-4">

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom fw-semibold py-3">
                            <i class="bi bi-grid-3x3-gap me-2 text-primary"></i>المرافق والمساحات
                        </div>
                        <div class="card-body">

                            @* الغرف *@
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-muted small">
                                    <i class="bi bi-door-open me-1 text-primary"></i>عدد الغرف
                                </label>
                                <div class="input-group">
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.Rooms = Math.Max(0, (Model.Rooms ?? 0) - 1)'>
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <InputNumber @bind-Value="Model.Rooms"
                                                 class="form-control text-center fw-bold fs-5"
                                                 min="0" max="999" />
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.Rooms = Math.Min(999, (Model.Rooms ?? 0) + 1)'>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => Model.Rooms)" class="text-danger small" />
                            </div>

                            @* الخيام *@
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-muted small">
                                    <i class="bi bi-wind me-1 text-primary"></i>عدد الخيام
                                </label>
                                <div class="input-group">
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.Tarpaulins = Math.Max(0, (Model.Tarpaulins ?? 0) - 1)'>
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <InputNumber @bind-Value="Model.Tarpaulins"
                                                 class="form-control text-center fw-bold fs-5"
                                                 min="0" max="999" />
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.Tarpaulins = Math.Min(999, (Model.Tarpaulins ?? 0) + 1)'>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => Model.Tarpaulins)" class="text-danger small" />
                            </div>

                            @* مساحات أخرى *@
                            <div class="mb-2">
                                <label class="form-label fw-semibold text-muted small">
                                    <i class="bi bi-grid me-1 text-primary"></i>مساحات أخرى
                                </label>
                                <div class="input-group">
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.OtherSpaces = Math.Max(0, (Model.OtherSpaces ?? 0) - 1)'>
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <InputNumber @bind-Value="Model.OtherSpaces"
                                                 class="form-control text-center fw-bold fs-5"
                                                 min="0" max="999" />
                                    <button type="button" class="btn btn-outline-secondary"
                                            @onclick='() => Model.OtherSpaces = Math.Min(999, (Model.OtherSpaces ?? 0) + 1)'>
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                <ValidationMessage For="@(() => Model.OtherSpaces)" class="text-danger small" />
                            </div>

                        </div>
                    </div>

                    @* ملخص سريع *@
                    <div class="card border-0 shadow-sm bg-primary bg-opacity-10">
                        <div class="card-body">
                            <div class="fw-semibold text-primary mb-2 small">
                                <i class="bi bi-eye me-1"></i>ملخص سريع
                            </div>
                            <ul class="list-unstyled mb-0 small">
                                <li class="d-flex justify-content-between py-1 border-bottom">
                                    <span class="text-muted">كود المركز</span>
                                    <span class="fw-semibold">@(Model.CenterCode ?? "—")</span>
                                </li>
                                <li class="d-flex justify-content-between py-1 border-bottom">
                                    <span class="text-muted">الغرف</span>
                                    <span class="fw-semibold text-primary">@(Model.Rooms ?? 0) غرفة</span>
                                </li>
                                <li class="d-flex justify-content-between py-1 border-bottom">
                                    <span class="text-muted">الخيام</span>
                                    <span class="fw-semibold text-primary">@(Model.Tarpaulins ?? 0) خيمة</span>
                                </li>
                                <li class="d-flex justify-content-between py-1">
                                    <span class="text-muted">مساحات أخرى</span>
                                    <span class="fw-semibold text-primary">@(Model.OtherSpaces ?? 0)</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>

            @* ══ أزرار الحفظ ══ *@
            <div class="card border-0 shadow-sm mt-2 mb-4">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="text-muted small">
                        <i class="bi bi-shield-lock me-1 text-success"></i>
                        التعديلات تُطبَّق على مركزك فقط
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="() => NavManager.NavigateTo(PagesUris.Home)"
                                disabled="@IsSaving">
                            <i class="bi bi-x-circle me-1"></i>إلغاء
                        </button>
                        <button type="submit"
                                class="btn btn-primary px-4"
                                disabled="@IsSaving">
                            @if (IsSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>جاري الحفظ...</span>
                            }
                            else
                            {
                                <i class="bi bi-floppy-fill me-1"></i>
                                <span>حفظ التعديلات</span>
                            }
                        </button>
                    </div>
                </div>
            </div>

        </EditForm>
    }
</div>

@code { }
