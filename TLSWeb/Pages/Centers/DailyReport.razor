@code {
    List<SharedLib.Entities.DailyReport> DailyReports = new();

    protected override async Task OnInitializedAsync()
    {
        DailyReports =await DailyReportApi.GetDailyReport();
    }

    private async Task SaveCenter(long CenterId)
    {
        var reportToSave = DailyReports.FirstOrDefault(r => r.CenterId == CenterId);

        if (reportToSave != null)
        {
            reportToSave.Center = null;
            var response = await DailyReportApi.UpdateDailyReport(reportToSave);
            if (response.Success)
                MudSnackbar.Add(response.Message, Severity.Success);
            else
                MudSnackbar.Add(response.Message, Severity.Error);
        }
    }

}
