@using TLSWeb.Components
@* @page "/admin/daily-report" *@
@attribute [Route(PagesUris.Admin.DailyReport)]
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@inject IAdminDashboardApi AdminApi
@inject ExcelDownloadService ExcelService

<div class="container-fluid px-4" dir="rtl">
    <AuthorizeView>
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            <div>
                <h3>
                    <i class="bi bi-calendar-day me-2 text-primary"></i>
                    التقرير اليومي للمراكز
                </h3>
                <p class="text-muted mb-0">تاريخ التقرير: @Report?.ReportDate.ToString("yyyy-MM-dd")</p>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-success" @onclick="ExportToExcel" disabled="@(IsLoading)">
                    @if(IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>جاري التصدير...</span>
                    }
                    else
                    {
                        <i class="bi bi-download me-1"></i>
                        <span>تصدير إلى Excel</span>
                    }
                </button>
            </div>
        </div>
    </AuthorizeView>
    @if (IsLoading)
    {
        <LoadingComponent/>
    }
    else if (Report != null && Report.Centers.Any())
    {
        <div class="m-2">
            <button type="button" class="btn btn-secondary" @onclick="ZoomIn"><i class="bi bi-zoom-in"></i></button>
            <button type="button" class="btn btn-secondary" @onclick="ZoomOut"><i class="bi bi-zoom-out"></i></button>
        </div>
        <div class="table-responsive" style="zoom: @Zoom;">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th rowspan="3" class="align-middle text-center">م</th>
                        <th rowspan="3" class="align-middle">كود المركز</th>
                        <th rowspan="3" class="align-middle">اسم المركز</th>
                        <th rowspan="3" class="align-middle">اسم المدير</th>
                        <th rowspan="3" class="align-middle">الفترة</th>
                        <th rowspan="3" class="align-middle text-center">حالة التقرير</th>
                        @foreach (var level in LevelNames)
                        {
                            <th colspan="4" class="text-center">@level</th>
                        }
                        <th rowspan="3" class="align-middle text-center">المسجلون الذكور</th>
                        <th rowspan="3" class="align-middle text-center">المسجلون الإناث</th>
                        <th rowspan="3" class="align-middle text-center">الحضور الذكور</th>
                        <th rowspan="3" class="align-middle text-center">الحضور الإناث</th>
                        <th rowspan="3" class="align-middle text-center">إجمالي المسجلين</th>
                        <th rowspan="3" class="align-middle text-center">إجمالي الحضور</th>
                    </tr>
                    <tr>
                        @foreach (var _ in LevelNames)
                        {
                            <th colspan="2" class="text-center">المسجلون</th>
                            <th colspan="2" class="text-center">الحضور</th>
                        }
                    </tr>
                    <tr>
                        @foreach (var _ in LevelNames)
                        {
                            <th class="text-center">ذكور</th>
                            <th class="text-center">إناث</th>
                            <th class="text-center">ذكور</th>
                            <th class="text-center">إناث</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Report.Centers.Count; i++)
                    {
                        var center = Report.Centers[i];
                        <tr>
                            <td class="text-center align-middle">@(i + 1)</td>
                            <td class="text-center align-middle">@center.CenterCode</td>
                            <td class="fw-bold align-middle">@center.CenterName</td>
                            <td class="fw-bold align-middle">@center.CenterManager</td>
                            <td class="fw-bold align-middle">@center.WHoures</td>
                            <td class="text-center align-middle">
                                @if (center.IsLocked)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-lock-fill me-1"></i>مؤمن
                                    </span>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-warning" @onclick="() => LockReport(center)">
                                        <i class="bi bi-unlock me-1"></i>تأمين
                                    </button>
                                }
                            </td>
                            @foreach (var level in LevelNames)
                            {
                                <td class="text-center align-middle">@center.RegisteredLevelMales[level]</td>
                                <td class="text-center align-middle">@center.RegisteredLevelFemales[level]</td>
                                <td class="text-center align-middle">@center.AttendanceLevelMales[level]</td>
                                <td class="text-center align-middle">@center.AttendanceLevelFemales[level]</td>
                            }
                            <td class="text-center fw-bold align-middle">@center.TotalRegisteredMales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalRegisteredFemales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalAttendanceMales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalAttendanceFemales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalRegisteredStudents</td>
                            <td class="text-center fw-bold align-middle">@center.TotalAttendanceStudents</td>
                        </tr>
                    }
                    <tr class="table-success fw-bold">
                        <td colspan="6" class="text-center">المجموع الكلي</td>
                        @foreach (var level in LevelNames)
                        {
                            <td class="text-center">@Report.LevelRegisteredMaleTotals[level]</td>
                            <td class="text-center">@Report.LevelRegisteredFemaleTotals[level]</td>
                            <td class="text-center">@Report.LevelAttendanceMaleTotals[level]</td>
                            <td class="text-center">@Report.LevelAttendanceFemaleTotals[level]</td>
                        }
                        <td class="text-center">@Report.GrandTotalRegisteredMales</td>
                        <td class="text-center">@Report.GrandTotalRegisteredFemales</td>
                        <td class="text-center">@Report.GrandTotalAttendanceMales</td>
                        <td class="text-center">@Report.GrandTotalAttendanceFemales</td>
                        <td class="text-center">@Report.GrandTotalRegisteredStudents</td>
                        <td class="text-center">@Report.GrandTotalAttendanceStudents</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
            <h5 class="text-muted mt-3">لا توجد بيانات للتقرير اليومي</h5>
        </div>
    }
</div>

@code {
    private DailyReportDto? Report;
    private bool IsLoading = true;
    private List<string> LevelNames = new();
    private float Zoom = 0.7f;

    protected override async Task OnInitializedAsync()
    {
        await LoadReport();
    }

    private async Task LoadReport()
    {
        IsLoading = true;
        try
        {
            Report = await AdminApi.GetDailyReport();
            if (Report?.LevelRegisteredMaleTotals.Any() == true)
            {
                LevelNames = Report.LevelRegisteredMaleTotals.Keys.ToList();
            }
        }
        catch (Exception ex)
        {
            // Handle error
            Console.WriteLine($"Error loading daily report: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ExportToExcel()
    {
        if (Report == null) return;

        try
        {
            // Note: Need to implement export endpoint in backend
            // var response = await AdminApi.ExportDailyReport();
            // await ExcelService.DownloadFromResponse(response, $"تقرير_يومي_{Report.ReportDate:yyyy-MM-dd}.xlsx");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting: {ex.Message}");
        }
    }

    private async Task LockReport(DailyCenterReport center)
    {
        if (Report == null) return;

        try
        {
            var request = new DailyReportLockRequest
            {
                ReportDate = Report.ReportDate,
                CenterId = center.CenterId,
                IsLocked = true
            };

            var response = await AdminApi.LockDailyReport(request);
            if (response.IsSuccessStatusCode)
            {
                await LoadReport(); // Reload to show updated lock status
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error locking report: {ex.Message}");
        }
    }

    private void ZoomIn() => Zoom += 0.1f;
    private void ZoomOut() => Zoom -= 0.1f;
}