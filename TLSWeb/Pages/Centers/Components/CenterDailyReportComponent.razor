<div class="card shadow-sm mb-5 border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="bi bi-house-door-fill me-2"></i> @item.Center?.Name
            <span style="color:darkred"> @(item.Id == 0 ? "  -  جديد" : "")  </span>
        </h5>
        <span class="small opacity-75">كود المركز: @item.Center?.CenterCode</span>
    </div>

    <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 120px;" class="bg-light">الصف</th>
                            @for (int i = 1; i <= 9; i++)
                            {
                                <th class="fw-bold">@Levels[i - 1]</th>
                            }
                        <th class="bg-warning text-dark" style="width: 110px;">الإجمالي العام</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="bg-light">
                            <td class="fw-bold text-muted small border-end-0">
                                <i class="bi bi-people-fill me-1"></i>المسجلين
                                <div class="text-xs text-secondary mt-1">(ذكر / أنثى)</div>
                            </td>
                            @for (int i = 1; i <= 9; i++)
                            {
                                var male = item.GetType().GetProperty($"RegMale0{i}")?.GetValue(item, null) ?? 0;
                                var female = item.GetType().GetProperty($"RegFemale0{i}")?.GetValue(item, null) ?? 0;
                                string regmalestr = $"RegMale0{i}";
                                string regfemalestr = $"RegFemale0{i}";
                            <td>
                                    <div class="d-grid gap-1">
                                    <span class="badge bg-info text-dark py-1" @onclick="@(() => OnRegValueClick(regmalestr))">@male</span>
                                    <span class="badge bg-light border text-dark py-1" @onclick="@(() => OnRegValueClick(regfemalestr))">@female</span>
                                    </div>
                                </td>
                            }
                            <td class="bg-primary bg-opacity-10 fw-bold border-start-0">
                                <div class="d-grid gap-1">
                                    <span class="badge bg-info text-dark py-1" title="إجمالي الذكور">@item.RegMaleTotal</span>
                                    <span class="badge bg-light border text-dark py-1" title="إجمالي الإناث">@item.RegFemaleTotal</span>
                                    <span class="badge bg-warning text-dark py-1 mt-1 border border-dark border-opacity-10">@item.RegTotal</span>
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td class="fw-bold text-success small border-end-0">
                                <i class="bi bi-check-circle-fill me-1"></i>الحضور
                                <div class="text-xs text-secondary mt-1">(ذكر / أنثى)</div>
                            </td>
                            @for (int i = 1; i <= 9; i++)
                            {
                                <td>
                                    <LevelComponent item="item"
                                                    MalePropertyName=@($"AttMale0{i}")
                                                    FemalePropertyName=@($"AttFemale0{i}")
                                                    Readonly=@ReadOnly />
                                </td>
                            }
                            <td class="bg-success bg-opacity-10 fw-bold border-start-0">
                                <div class="d-grid gap-1">
                                    <span class="badge bg-info text-dark py-1">@item.AttMaleTotal</span>
                                    <span class="badge bg-light border text-dark py-1">@item.AttFemaleTotal</span>
                                    <span class="badge bg-warning text-dark py-1 mt-1 border border-dark border-opacity-10">@item.AttTotal</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        

        
        <div class="p-3 border-top bg-light">
            <div class="row g-2 align-items-center">

                <div class="col compact-field">
                    <label class="compact-label"> لاجىء حاضر</label>
                    <InputNumber @bind-Value="item.IsUNRWA" class="form-control form-control-xs border-danger shadow-sm" disabled="@ReadOnly" />
                </div>

                <div class="col compact-field">
                    <label class="compact-label">غير لاجئ حاضر</label>
                    <input type="number" class="form-control form-control-xs bg-white shadow-sm" value="@item.IsNotUNRWA" disabled />
                </div>

                <div class="col-md-1 compact-field">
                    <label class="compact-label">إعاقة</label>
                    <input type="number" class="form-control form-control-xs bg-white shadow-sm" value="@item.Disabilities" disabled />
                </div>

                <div class="col compact-field">
                    <label class="compact-label text-primary">البسكويت الموزع</label>
                    <InputNumber @bind-Value="item.WFPBiscDist" class="form-control form-control-xs border-primary shadow-sm" disabled="@ReadOnly" />
                </div>

                <div class="col compact-field">
                    <label class="compact-label text-danger">البسكويت التالف</label>
                    <InputNumber @bind-Value="item.WFPBiscLost" class="form-control form-control-xs border-danger shadow-sm" disabled="@ReadOnly" />
                </div>

                <div class="col compact-field">
                    <label class="compact-label text-dark">إجمالي البسكويت</label>
                    <input type="number" class="form-control form-control-xs bg-warning bg-opacity-10 fw-bold shadow-sm" value="@item.WFPBiscTotal" disabled />
                </div>

                <div class="col-auto pt-2">
                    <div class="form-check form-switch">
                        <InputCheckbox @bind-Value="item.IsLocked" class="form-check-input" id="lockSwitch" disabled="@ReadOnly" />
                        <label class="form-check-label small fw-bold" for="lockSwitch">قفل</label>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="card-footer bg-white text-muted small d-flex justify-content-between align-items-center p-3">
        <span><i class="bi bi-clock me-1"></i> تاريخ التقرير: @item.ReportDate.ToString("yyyy/MM/dd")</span>
        <span> المتبقي من البسكويت : @Rest</span>
            @if (!ReadOnly)
        {
            <button class="btn btn-success btn-lg px-5 shadow-sm" @onclick="() => SaveCenter()">
                <i class="bi bi-check-circle me-2"></i>
                حفظ البيانات
            </button>
        }
        else
        {
            <span class="badge bg-danger p-2 px-3"><i class="bi bi-lock-fill me-1"></i> التقرير مغلق</span>
        }
    </div>
</div>
 

@code {
    [Parameter] public DailyReport item { get; set; }
    string[] Levels = new[] { "الصف الأول", "الصف الثاني", "الصف الثالث", "الصف الرابع", "الصف الخامس", "الصف السادس", "الصف السابع", "الصف الثامن", "الصف التاسع" };
    bool ReadOnly = false;
    string UserName = string.Empty;
    string UserEmail = string.Empty;
    string UserRole = string.Empty;
    decimal Rest = 0;

    protected async override Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity!.IsAuthenticated)
        {
            UserName = user.Identity.Name!;
            UserEmail = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value!;
            UserRole = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value!;
        }

        if (user.IsInRole("Admin") )
            ReadOnly = false;
        else
            if (/* item.ReportDate != DateOnly.FromDateTime(DateTime.Now) && */ item.IsLocked)
                ReadOnly = item.IsLocked;

        var TotalReceived = await InComeApi.GetBuildingTotal(item.Center?.BuildingCode);
        var TotalDist = await DailyReportApi.GetBuildingTotalDist(item.Center?.BuildingCode);
        Rest = TotalReceived - TotalDist;
    }

    private async Task SaveCenter()
    {
        var reportToSave = item;

        if (reportToSave != null)
        {
            if (reportToSave.IsUNRWA > reportToSave.RegUNRWA)
            {
                MudSnackbar.Add("لا يمكن أن يكون طلاب الأنرو الحضور أكبر من المسجلين !", Severity.Error);
                return;
            }
            else
             if (reportToSave.IsUNRWA ==0 && reportToSave.RegUNRWA > 0)
            {
                MudSnackbar.Add("لا يمكن أن يكون طلاب الأنرو الحضور صفر !", Severity.Error);
                return;
            }
            Center center = reportToSave.Center;
            reportToSave.Center = null;

            if (UserRole!="Admin")
                reportToSave.IsLocked = true;

            reportToSave.LockedAt = DateTime.Now;
            reportToSave.LockedBy = UserName;
            var response = await DailyReportApi.UpdateDailyReport(reportToSave);
            if (response.Success)
                MudSnackbar.Add(response.Message, Severity.Success);
            else
                MudSnackbar.Add(response.Message, Severity.Error);
            item.Center = center;
            StateHasChanged();
        }
    }

    void OnRegValueClick(string propertyName)
    {

        if (ReadOnly) return;

        var regValue = item.GetType().GetProperty(propertyName)?.GetValue(item, null) ?? 0;
        string AttName = propertyName.Replace("Reg", "Att");
        item.GetType().GetProperty(AttName)?.SetValue(item, regValue);
    }
}
