        @if (!ReadOnly)
        {
            <button class="btn btn-success btn-lg px-5 shadow-sm" @onclick="() => SaveCenter()">
                <i class="bi bi-check-circle me-2"></i>
                حفظ البيانات
            </button>
        }
        else
        {
            <span class="badge bg-danger p-2 px-3"><i class="bi bi-lock-fill me-1"></i> التقرير مغلق</span>
        }
    </div>
</div>
 

@code {
    [Parameter] public DailyReport item { get; set; }
    string[] Levels = new[] { "الصف الأول", "الصف الثاني", "الصف الثالث", "الصف الرابع", "الصف الخامس", "الصف السادس", "الصف السابع", "الصف الثامن", "الصف التاسع" };
    bool ReadOnly = false;
    string UserName = string.Empty;
    string UserEmail = string.Empty;
    string UserRole = string.Empty;

    protected async override Task OnInitializedAsync()
    {
        var authState = await authenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity!.IsAuthenticated)
        {
            UserName = user.Identity.Name!;
            UserEmail = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value!;
            UserRole = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value!;
        }

        if (user.IsInRole("Admin") )
            ReadOnly = false;
        else
        if (item.ReportDate != DateOnly.FromDateTime(DateTime.Now) && item.IsLocked)
            ReadOnly = true;
    }

    private async Task SaveCenter()
    {
        var reportToSave = item;

        if (reportToSave != null)
        {
            Center center = reportToSave.Center;
            reportToSave.Center = null;
            var response = await DailyReportApi.UpdateDailyReport(reportToSave);
            if (response.Success)
                MudSnackbar.Add(response.Message, Severity.Success);
            else
                MudSnackbar.Add(response.Message, Severity.Error);

            item.Center = center;
        }
    }
}
