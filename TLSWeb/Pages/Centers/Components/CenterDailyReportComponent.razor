                                       min="0" max="@item.RegFemale07" placeholder="♀">
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <input type="number" name="item.AttMale08"
                                       @bind-value="item.AttMale08"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegMale08" placeholder="♂">

                                <input type="number" name="item.AttFemale08"
                                       @bind-value="item.AttFemale08"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegFemale08" placeholder="♀">
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <input type="number" name="item.AttMale09"
                                       @bind-value="item.AttMale09"
                                       class="form-control form-control-sm text-center border-success"
