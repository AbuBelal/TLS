                                <input type="number" name="item.AttFemale04"
                                       @bind-value="item.AttFemale04"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegFemale04" placeholder="♀">
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <input type="number" name="item.AttMale05"
                                       @bind-value="item.AttMale05"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegMale05" placeholder="♂">

                                <input type="number" name="item.AttFemale05"
                                       @bind-value="item.AttFemale05"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegFemale05" placeholder="♀">
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <input type="number" name="item.AttMale06"
                                       @bind-value="item.AttMale06"
                                       class="form-control form-control-sm text-center border-success"
                                       min="0" max="@item.RegMale06" placeholder="♂">

                                <input type="number" name="item.AttFemale06"
                                       @bind-value="item.AttFemale06"
                                       class="form-control form-control-sm text-center border-success"
