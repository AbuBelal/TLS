@* ╔══════════════════════════════════════════════════════════════╗ *@
@* ║  TLSWeb/Pages/Centers/CenterEdit.razor                       ║ *@
@* ║  صفحة تعديل بيانات المركز — لمدير المركز (Role=User) فقط   ║ *@
@* ╚══════════════════════════════════════════════════════════════╝ *@

@* @attribute [Route(PagesUris.CenterPages.Edit)] *@

<div class="container-fluid px-4 border-2 " dir="rtl" style="background:@BackgroundColor">

    @* ══ رأس الصفحة ══ *@
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="mb-0">
            <i class="bi bi-building-gear me-2 text-primary"></i>تعديل بيانات المركز
        </h3>
    </div>

    @* ══ تحميل ══ *@
@if (IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:50vh">
            <div class="text-center">
                <div class="spinner-border text-primary" style="width:3rem;height:3rem" role="status"></div>
                <p class="mt-3 text-muted small">جاري تحميل بيانات المركز...</p>
            </div>
        </div>
    }
    @* ══ خطأ ══ *@
    else if (ErrorMsg is not null)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2 mt-3">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span>@ErrorMsg</span>
        </div>
    }
    @* ══ النموذج ══ *@
    else
    {
        @* ============================================
   توليد class الخلفية ديناميكياً حسب كود المركز
   ============================================ *@
        <EditForm Model="@Model" OnValidSubmit="HandleSubmit" class="@GetThemeClass()">
            <DataAnnotationsValidator />

            @* ── الخلفية الزخرفية العائمة ── *@
            <div class="ambient-bg">
                <div class="ambient-circle circle-1"></div>
                <div class="ambient-circle circle-2"></div>
                <div class="ambient-circle circle-3"></div>
            </div>

            <div class="container-fluid py-4 position-relative" style="z-index: 1;">

                @* ── رأس الصفحة ── *@
                <div class="page-header mb-4 animate-fade-in">
                    <div class="d-flex align-items-center gap-3">
                        <div class="header-icon">
                            <i class="bi bi-buildings fs-3"></i>
                        </div>
                        <div>
                            <h4 class="mb-1 fw-bold text-gradient">تعديل بيانات المركز</h4>
                            <p class="text-muted mb-0 small">قم بتحديث معلومات المركز والمرافق التابعة له</p>
                        </div>
                    </div>
                    <div class="badge-glass mt-2 mt-md-0">
                        <i class="bi bi-person-badge me-1"></i>
                        <span>مدير المركز: <strong>@Model.ManagerName</strong></span>
                    </div>
                </div>

                <div class="row g-4">

                    @* ═══════════════════════════════════════
               العمود الأيمن: المعلومات الأساسية
               ═══════════════════════════════════════ *@
                    <div class="col-lg-8">

                        @* ── بطاقة المعلومات الأساسية ── *@
                        <div class="glass-card mb-4 animate-slide-up">
                            <div class="card-glow"></div>
                            <div class="card-header-glass">
                                <div class="header-accent"></div>
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <span>المعلومات الأساسية</span>
                            </div>
                            <div class="card-body p-4">
                                <div class="row g-3">

                                    @* اسم المركز *@
                                    <div class="col-md-8">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-building me-1 text-primary"></i>
                                            اسم المركز <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group-modern">
                                            <InputText @bind-Value="Model.Name" disabled=@(!IsAdmin)
                                            class="form-control modern-input"
                                            placeholder="أدخل اسم المركز" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.Name)" class="text-danger small mt-1" />
                                    </div>

                                    @* كود المركز *@
                                    <div class="col-md-4">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-upc-scan me-1 text-primary"></i>
                                            كود المركز
                                        </label>
                                        <div class="input-group-modern">
                                            <InputText @bind-Value="Model.CenterCode" disabled=@(!IsAdmin)
                                            class="form-control modern-input font-monospace"
                                            placeholder="JB-001" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.CenterCode)" class="text-danger small mt-1" />
                                    </div>

                                    @* اسم المركز بالإنجليزية *@
                                    <div class="col-md-8">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-globe me-1 text-primary"></i>
                                            اسم المركز بالإنجليزية <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group-modern">
                                            <InputText @bind-Value="Model.EnName" disabled=@(!IsAdmin)
                                            class="form-control modern-input"
                                            placeholder="Enter center name in English" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.EnName)" class="text-danger small mt-1" />
                                    </div>

                                    @* رقم المبنى *@
                                    <div class="col-md-2">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-house-door me-1 text-primary"></i>
                                            رقم المبنى
                                        </label>
                                        <div class="input-group-modern">
                                            <InputText @bind-Value="Model.BuildingCode" disabled=@(!IsAdmin)
                                            class="form-control modern-input text-center font-monospace"
                                            placeholder="2xxxxxx" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.BuildingCode)" class="text-danger small mt-1" />
                                    </div>

                                    @* ترتيب العرض *@
                                    <div class="col-md-2">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-sort-numeric-down me-1 text-primary"></i>
                                            الترتيب
                                        </label>
                                        <div class="input-group-modern">
                                            <InputNumber @bind-Value="Model.SortOrder" disabled=@(!IsAdmin)
                                            class="form-control modern-input text-center"
                                            placeholder="01" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.SortOrder)" class="text-danger small mt-1" />
                                    </div>

                                    @* العنوان *@
                                    <div class="col-md-8">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-geo-alt me-1 text-primary"></i>
                                            العنوان
                                        </label>
                                        <div class="input-group-modern">
                                            <InputText @bind-Value="Model.Address"
                                            class="form-control modern-input"
                                            placeholder="الحي، الشارع، المنطقة" />
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.Address)" class="text-danger small mt-1" />
                                    </div>

                                    @* فترة الدوام *@
                                    <div class="col-md-4">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-clock-history me-1 text-primary"></i>
                                            فترة الدوام
                                        </label>
                                        <div class="input-group-modern">
                                            <InputSelect @bind-Value="Model.WHours" class="form-select modern-input">
                                                <option value="">-- اختر فترة الدوام --</option>
                                                @foreach (var g in WHoures)
                                                {
                                                    <option value="@g.Id">@g.Name</option>
                                                }
                                            </InputSelect>
                                            <div class="input-glow"></div>
                                        </div>
                                        <ValidationMessage For="@(() => Model.WHours)" class="text-danger small mt-1" />
                                    </div>

                                    @* ملاحظات *@
                                    <div class="col-12">
                                        <label class="form-label modern-label">
                                            <i class="bi bi-chat-square-text me-1 text-primary"></i>
                                            ملاحظات
                                        </label>
                                        <div class="input-group-modern">
                                            <InputTextArea @bind-Value="Model.Comments"
                                            class="form-control modern-input"
                                            rows="3"
                                            placeholder="أي ملاحظات إضافية..." />
                                            <div class="input-glow"></div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        @* ── بطاقة أيام الدوام ── *@
                        <div class="glass-card mb-4 animate-slide-up" style="animation-delay: 0.1s;">
                            <div class="card-glow"></div>
                            <div class="card-header-glass">
                                <div class="header-accent"></div>
                                <i class="bi bi-calendar-week-fill me-2"></i>
                                <span>أيام الدوام</span>
                                <span class="text-danger ms-1">*</span>
                            </div>
                            <div class="card-body p-4">
                                <div class="days-selector d-flex flex-wrap gap-2 mb-3">
                                    @foreach (var day in AllDays)
                                    {
                                        var selected = IsDaySelected(day);
                                        <button type="button" disabled=@(!IsAdmin)
                                        class="day-chip @(selected ? "active" : "")"
                                        @onclick="() => ToggleDay(day)">
                                            @if (selected)
                                            {
                                                <i class="bi bi-check2-circle me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-circle me-1 opacity-50"></i>
                                            }
                                            @day
                                        </button>
                                    }
                                </div>

                                @* عرض النص المُولَّد *@
                                <div class="selected-days-preview">
                                    <div class="preview-icon">
                                        <i class="bi bi-calendar-check fs-4"></i>
                                    </div>
                                    <div class="preview-content">
                                        <small class="text-muted d-block">أيام الدوام المحددة</small>
                                        <span class="fw-bold">
                                            @(string.IsNullOrEmpty(Model.DaysOfWeek) ? "لم يتم اختيار أيام بعد" : Model.DaysOfWeek)
                                        </span>
                                    </div>
                                </div>

                                <ValidationMessage For="@(() => Model.DaysOfWeek)" class="text-danger small d-block mt-2" />
                            </div>
                        </div>

                    </div>

                    @* ═══════════════════════════════════════
               العمود الأيسر: المرافق والملخص
               ═══════════════════════════════════════ *@
                    <div class="col-lg-4">

                        @* ── بطاقة المرافق ── *@
                        <div class="glass-card mb-4 animate-slide-up" style="animation-delay: 0.2s;">
                            <div class="card-glow"></div>
                            <div class="card-header-glass">
                                <div class="header-accent"></div>
                                <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                                <span>المرافق والمساحات</span>
                            </div>
                            <div class="card-body p-4">

                                @* الغرف *@
                                <div class="facility-item mb-4">
                                    <label class="facility-label">
                                        <span class="facility-icon bg-primary bg-opacity-10 text-primary">
                                            <i class="bi bi-door-open"></i>
                                        </span>
                                        <span class="facility-title">عدد الغرف</span>
                                    </label>
                                    <div class="counter-modern">
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.Rooms = Math.Max(0, (Model.Rooms ?? 0) - 1)'>
                                            <i class="bi bi-dash-lg"></i>
                                        </button>
                                        <InputNumber @bind-Value="Model.Rooms"
                                        class="counter-input"
                                        min="0" max="999" />
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.Rooms = Math.Min(999, (Model.Rooms ?? 0) + 1)'>
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => Model.Rooms)" class="text-danger small mt-1" />
                                </div>

                                @* الخيام *@
                                <div class="facility-item mb-4">
                                    <label class="facility-label">
                                        <span class="facility-icon bg-success bg-opacity-10 text-success">
                                            <i class="bi bi-wind"></i>
                                        </span>
                                        <span class="facility-title">عدد الخيام</span>
                                    </label>
                                    <div class="counter-modern">
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.Tarpaulins = Math.Max(0, (Model.Tarpaulins ?? 0) - 1)'>
                                            <i class="bi bi-dash-lg"></i>
                                        </button>
                                        <InputNumber @bind-Value="Model.Tarpaulins"
                                        class="counter-input"
                                        min="0" max="999" />
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.Tarpaulins = Math.Min(999, (Model.Tarpaulins ?? 0) + 1)'>
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => Model.Tarpaulins)" class="text-danger small mt-1" />
                                </div>

                                @* مساحات أخرى *@
                                <div class="facility-item">
                                    <label class="facility-label">
                                        <span class="facility-icon bg-warning bg-opacity-10 text-warning">
                                            <i class="bi bi-grid"></i>
                                        </span>
                                        <span class="facility-title">مساحات أخرى</span>
                                    </label>
                                    <div class="counter-modern">
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.OtherSpaces = Math.Max(0, (Model.OtherSpaces ?? 0) - 1)'>
                                            <i class="bi bi-dash-lg"></i>
                                        </button>
                                        <InputNumber @bind-Value="Model.OtherSpaces"
                                        class="counter-input"
                                        min="0" max="999" />
                                        <button type="button" class="counter-btn"
                                        @onclick='() => Model.OtherSpaces = Math.Min(999, (Model.OtherSpaces ?? 0) + 1)'>
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => Model.OtherSpaces)" class="text-danger small mt-1" />
                                </div>

                            </div>
                        </div>

                        @* ── بطاقة الملخص السريع ── *@
                        <div class="glass-card summary-card animate-slide-up" style="animation-delay: 0.3s;">
                            <div class="card-glow"></div>
                            <div class="summary-header">
                                <i class="bi bi-eye-fill me-2"></i>
                                <span>ملخص سريع</span>
                            </div>
                            <div class="card-body p-0">
                                <ul class="summary-list">
                                    <li>
                                        <span class="summary-icon"><i class="bi bi-upc"></i></span>
                                        <span class="summary-label">كود المركز</span>
                                        <span class="summary-value font-monospace">@(Model.CenterCode ?? "—")</span>
                                    </li>
                                    <li>
                                        <span class="summary-icon text-primary"><i class="bi bi-door-open"></i></span>
                                        <span class="summary-label">الغرف</span>
                                        <span class="summary-value text-primary fw-bold">@(Model.Rooms ?? 0)</span>
                                    </li>
                                    <li>
                                        <span class="summary-icon text-success"><i class="bi bi-wind"></i></span>
                                        <span class="summary-label">الخيام</span>
                                        <span class="summary-value text-success fw-bold">@(Model.Tarpaulins ?? 0)</span>
                                    </li>
                                    <li class="border-0">
                                        <span class="summary-icon text-warning"><i class="bi bi-grid"></i></span>
                                        <span class="summary-label">مساحات أخرى</span>
                                        <span class="summary-value text-warning fw-bold">@(Model.OtherSpaces ?? 0)</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                    </div>
                </div>

                @* ═══════════════════════════════════════
           أزرار الحفظ
           ═══════════════════════════════════════ *@
                <div class="glass-card mt-4 animate-slide-up" style="animation-delay: 0.4s;">
                    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3 p-4">
                        <div class="security-notice">
                            <div class="security-icon">
                                <i class="bi bi-shield-check-fill"></i>
                            </div>
                            <div>
                                <span class="d-block fw-semibold small">حماية البيانات</span>
                                <span class="text-muted smaller">التعديلات تُطبَّق على مركزك فقط</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button"
                            class="btn btn-modern btn-cancel"
                            @onclick="() => NavManager.NavigateTo(PagesUris.Home)"
                            disabled="@IsSaving">
                                <i class="bi bi-x-lg me-1"></i>
                                إلغاء
                            </button>
                            <button type="submit"
                            class="btn btn-modern btn-save"
                            disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>جاري الحفظ...</span>
                                }
                                else
                                {
                                    <i class="bi bi-floppy-fill me-1"></i>
                                    <span>حفظ التعديلات</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </EditForm>
    }
    </div>
