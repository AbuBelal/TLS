@using TLSWeb.Components
@* @page "/admin/detailed-centers-report" *@
@attribute [Route(PagesUris.Admin.DetailedCentersReport)]
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@inject IAdminDashboardApi AdminApi
@inject ExcelDownloadService ExcelService

<div class="container-fluid px-4" dir="rtl">
    <AuthorizeView>
        <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
            <h3>
                <i class="bi bi-table me-2 text-primary"></i>
                تقرير مفصل لبيانات المراكز
            </h3>

            @*  <button class="btn btn-success" @onclick="ExportToExcel">
                <i class="bi bi-download me-1"></i>
                تصدير إلى Excel
            </button>  *@
            <button class="btn btn-success" @onclick="ExportToExcel" disabled="@(IsLoading)">
                @if(IsLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>جاري التصدير...</span>
                }
                else
                {
                    <i class="bi bi-download me-1"></i>
                    <span>تصدير إلى Excel</span>
                }
            </button>
        </div>
    </AuthorizeView>
    @if (IsLoading)
    {
       @*  <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">جاري تحميل البيانات...</p>
        </div> *@
        <LoadingComponent/>
    }
    else if (Report != null)
    {
        <div class="m-2">
            <button type="button" class="btn btn-secondary" @onclick="ZoomIn"><i class="bi bi-zoom-in"></i></button>
            <button type="button" class="btn btn-secondary" @onclick="ZoomOut"><i class="bi bi-zoom-out"></i></button>

        </div>
        <div class="table-responsive" style="zoom: @Zoom;">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th rowspan="2" class="align-middle text-center">م</th>
                        <th rowspan="2" class="align-middle">كود المركز</th>
                        <th rowspan="2" class="align-middle">اسم المركز</th>
                        <th rowspan="2" class="align-middle">اسم المدير</th>
                        <th rowspan="2" class="align-middle">الفترة</th>
                        @foreach (var level in LevelNames)
                        {
                            <th colspan="2" class="text-center">@level</th>
                        }
                        <th rowspan="2" class="align-middle text-center">أنروا</th>
                        <th rowspan="2" class="align-middle text-center">غير الأنروا</th>
                        <th rowspan="2" class="align-middle text-center">احتياجات خاصة</th>
                        <th rowspan="2" class="align-middle text-center">مجموع الذكور</th>
                        <th rowspan="2" class="align-middle text-center">مجموع الإناث</th>
                        <th rowspan="2" class="align-middle text-center">المجموع الكلي</th>
                        <th rowspan="2" class="align-middle text-center">الغرف</th>
                        <th rowspan="2" class="align-middle text-center">الخيم</th>
                        <th rowspan="2" class="align-middle text-center">مساحات أخرى</th>
                    </tr>
                    <tr>
                        @foreach (var _ in LevelNames)
                        {
                            <th class="text-center">ذكور</th>
                            <th class="text-center">إناث</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Report.Centers.Count; i++)
                    {
                        var center = Report.Centers[i];
                        <tr>
                            <td class="text-center align-middle">@(i + 1)</td>
                            <td class="text-center align-middle">@center.CenterCode</td>
                            <td class="fw-bold align-middle">@center.CenterName</td>
                            <td class="fw-bold align-middle">@center.CenterManager</td>
                            <td class="fw-bold align-middle">@center.WHoures</td>
                            @foreach (var level in LevelNames)
                            {
                                <td class="text-center align-middle">@center.LevelMales[level]</td>
                                <td class="text-center align-middle">@center.LevelFemales[level]</td>
                            }
                            <td class="text-center align-middle">@center.UnrwaCount</td>
                            <td class="text-center align-middle">@(center.TotalStudents - center.UnrwaCount)</td>
                            <td class="text-center align-middle">@center.SpecialNeedsCount</td>
                            <td class="text-center fw-bold align-middle">@center.TotalMales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalFemales</td>
                            <td class="text-center fw-bold align-middle">@center.TotalStudents</td>
                            <td class="text-center fw-bold align-middle">@center.TotalRooms</td>
                            <td class="text-center fw-bold align-middle">@center.TotalTarpaulins</td>
                            <td class="text-center fw-bold align-middle">@center.TotalOtherSpaces</td>
                        </tr>
                    }
                    <tr class="table-success fw-bold">
                        <td colspan="5" class="text-center">المجموع الكلي</td>
                        @foreach (var level in LevelNames)
                        {
                            <td class="text-center">@Report.LevelMaleTotals[level]</td>
                            <td class="text-center">@Report.LevelFemaleTotals[level]</td>
                        }
                        <td class="text-center">@Report.GrandTotalUnrwa</td>
                        <td class="text-center">@(Report.GrandTotalStudents + Report.GrandTotalUnrwa)</td>
                        <td class="text-center">@Report.GrandTotalSpecialNeeds</td>
                        <td class="text-center">@Report.GrandTotalMales</td>
                        <td class="text-center">@Report.GrandTotalFemales</td>
                        <td class="text-center">@Report.GrandTotalStudents</td>
                        <td class="text-center">@Report.GrandTotalRooms</td>
                        <td class="text-center">@Report.GrandTotalTarpaulins</td>
                        <td class="text-center">@Report.GrandTotalOtherSpaces</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private DetailedCentersReportDto? Report;
    private bool IsLoading = true;
    private List<string> LevelNames = new();
    private float Zoom = 0.7f;
    protected override async Task OnInitializedAsync()
    {
        Report = await AdminApi.GetDetailedReport();
        if (Report?.LevelMaleTotals.Any() == true)
        {
            LevelNames = Report.LevelMaleTotals.Keys.ToList();
        }
        IsLoading = false;
    }

    private async Task ExportToExcel()
    {
        if (Report == null) return;
        
        var response = await AdminApi.ExportDetailedReport();
        await ExcelService.DownloadFromResponse(response, "تقرير_المراكز_المفصل.xlsx");
    }

    private void ZoomIn() => Zoom += 0.1f;
    private void ZoomOut() => Zoom -= 0.1f;

}