@using SharedLib.Mapper
@attribute [Route(PagesUris.InComePages.Manage)]
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="mb-0">
            <i class="bi bi-cash-coin me-2 text-success"></i>
            إدارة الواردات
        </h3>
        <div class="d-flex gap-2" dir="rtl">
            <button class="btn btn-success shadow-sm" @onclick="OpenAddPage">
                <i class="bi bi-plus-circle me-1"></i> إضافة وارد
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">جاري التحميل...</span>
            </div>
            <p class="mt-2 text-muted">جاري تحميل البيانات...</p>
        </div>
    }
    else if (!incomes.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-cash fs-1 d-block mb-2"></i>
            <p class="fs-5 fw-semibold">لا توجد بيانات للعرض</p>
            <p class="small">جرب إضافة وارد جديد</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 fs-6">
                        <i class="bi bi-clipboard-data me-1"></i> عدد الوارد: <strong>@totalCount</strong>
                    </span>
                    <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 fs-6">
                        <i class="bi bi-wallet2 me-1"></i> الكمية الإجمالية: <strong>@totalAmount.ToString("N0")</strong> د.ع
                    </span>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>اسم الوارد</th>
                            <th>المبلغ</th>
                            <th>التاريخ</th>
                            <th>المركز</th>
                            <th>المستلم</th>
                            <th style="width: 200px;" class="text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var row = 0;
                        }
                        @foreach (var income in pagedIncomes)
                        {
                            row++;
                            <tr>
                                <td class="text-muted small">@(((currentPage - 1) * pageSize) + row)</td>
                                <td>
                                    <div class="fw-semibold">@income.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(income.Comments))
                                    {
                                        <small class="text-muted">@income.Comments</small>
                                    }
                                </td>
                                <td><span class="badge bg-success bg-opacity-10 text-success fw-bold fs-5">@income.Qnty.ToString("N0")</span></td>
                                <td>@income.Date.ToString("dd/MM/yyyy")</td>
                                <td>@income.CenterName</td>
                                <td>@(string.IsNullOrEmpty(income.RecipientName) ? "-" : income.RecipientName)</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="@(() => OpenEditPage(income.Id))" title="تعديل">
                                            <i class="bi bi-pencil-square"></i> تعديل
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick="@(() => ConfirmDelete(income))" title="حذف">
                                            <i class="bi bi-trash"></i> حذف
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">
                                عرض @(((currentPage - 1) * pageSize) + 1)
                                إلى @(Math.Min(currentPage * pageSize, totalCount))
                                من أصل @totalCount
                            </span>
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="@(() => GoToPageAsync(1))">
                                            <i class="bi bi-chevron-double-right"></i>
                                        </button>
                                    </li>
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="@(() => GoToPageAsync(currentPage - 1))">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                    </li>

                                    @foreach (var pageNo in GetPageNumbers())
                                    {
                                        <li class="page-item @(pageNo == currentPage ? "active" : "")">
                                            <button class="page-link" @onclick="@(() => GoToPageAsync(pageNo))"> @pageNo </button>
                                        </li>
                                    }

                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="@(() => GoToPageAsync(currentPage + 1))">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                    </li>
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="@(() => GoToPageAsync(totalPages))">
                                            <i class="bi bi-chevron-double-left"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && incomeToDelete is not null)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title">تأكيد الحذف</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">
                        هل أنت متأكد من حذف الإيراد <strong>@incomeToDelete.Name</strong>؟
                    </p>
                    <p class="text-muted small">المبلغ: @incomeToDelete.Qnty.ToString("N0") د.ع</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="CancelDelete" disabled="@isDeleting">إلغاء</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteConfirmedAsync" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        حذف
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code
 {
                      
    private List<InComeDto> incomes = new();
    private List<InComeDto> pagedIncomes = new();
    private InComeDto? incomeToDelete;
    private bool isLoading = true;
    private bool isDeleting = false;
    private bool showDeleteModal = false;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 0;
    private decimal totalAmount = 0;
    protected override async Task OnInitializedAsync()
    {
        await LoadIncomesAsync();
    }

    private async Task LoadIncomesAsync()
    {
        isLoading = true;
        try
        {
            incomes = await InComeApi.GetAll();
            totalCount = incomes.Count;
            totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
            totalAmount = incomes.Sum(i => i.Qnty);
            UpdatePagedIncomes();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading incomes: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void UpdatePagedIncomes()
    {
        pagedIncomes = incomes
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void OpenAddPage()
    {
        NavManager.NavigateTo(PagesUris.InComePages.Add);
    }

    private void OpenEditPage(long id)
    {
        NavManager.NavigateTo(PagesUris.InComePages.Edit + $"/{id}");
    }

    private void ConfirmDelete(InComeDto income)
    {
        incomeToDelete = income;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        incomeToDelete = null;
    }

    private async Task DeleteConfirmedAsync()
    {
        if (incomeToDelete is null) return;

        isDeleting = true;
        try
        {
            var result = await InComeApi.Delete(incomeToDelete.Id);
            if (result)
            {
                await LoadIncomesAsync();
                showDeleteModal = false;
                incomeToDelete = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting income: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        int start = Math.Max(1, currentPage - 2);
        int end = Math.Min(totalPages, currentPage + 2);

        for (int i = start; i <= end; i++)
        {
            pages.Add(i);
        }
        return pages;
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > totalPages || page == currentPage) return;
        currentPage = page;
        UpdatePagedIncomes();
    }
}
                  