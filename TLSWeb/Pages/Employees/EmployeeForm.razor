<div class="container mt-4 mb-10">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">تنقلات المرظف </h4>
        </div>
<div class="table-responsive shadow-sm rounded m-2" >
    <table class="table table-hover table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3">اسم المركز</th>
                <th scope="col" class="py-3">تاريخ البدء (من)</th>
                <th scope="col" class="py-3">تاريخ الانتهاء (إلى)</th>
                <th scope="col" class="py-3">الحالة</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var empcenter in employee.EmpCenters?.OrderByDescending(x => x.FromDate))
            {
                <tr>
                    <td class="fw-bold text-primary">
                        @empcenter.Center?.Name
                    </td>
                    <td>
                        <i class="bi bi-calendar-check me-1"></i>
                        @empcenter.FromDate.ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        @if (empcenter.ToDate.HasValue)
                        {
                            <i class="bi bi-calendar-x me-1"></i>
                            @empcenter.ToDate.Value.ToString("dd/MM/yyyy")
                        }
                        else
                        {
                            <span class="text-muted italic">-- / -- / ----</span>
                        }
                    </td>
                    <td>
                        @if (!empcenter.ToDate.HasValue)
                        {
                            <span class="badge bg-success">حالي</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">سابق</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>
</div>


@* 
<h3>@(Id == 0 ? "إضافة موظف جديد" : "تعديل بيانات الموظف")</h3>

<EditForm Model="@employee" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row">
        <!-- البيانات الأساسية -->
        <div class="col-md-6 mb-3">
            <label>الاسم (مطلوب)</label>
            <InputText class="form-control" @bind-Value="employee.Name" />
        </div>
        <div class="col-md-6 mb-3">
            <label>الرقم المدني (مطلوب)</label>
            <InputText class="form-control" @bind-Value="employee.CivilId" />
        </div>
        <div class="col-md-6 mb-3">
            <label>رقم الموظف (مطلوب)</label>
            <InputText class="form-control" @bind-Value="employee.EmpId" />
        </div>
        <div class="col-md-6 mb-3">
            <label>تاريخ الميلاد</label>
            <InputDate class="form-control" @bind-Value="employee.BirthDate" />
        </div>
        <div class="col-md-6 mb-3">
            <label>الجوال</label>
            <InputText class="form-control" @bind-Value="employee.Mobile" />
        </div>
        <div class="col-md-6 mb-3">
            <label>العنوان</label>
            <InputText class="form-control" @bind-Value="employee.Address" />
        </div>

        <!-- البيانات الوظيفية (القوائم المنسدلة) -->
        <div class="col-md-6 mb-3">
            <label>الجنس</label>
            <InputSelect class="form-control" @bind-Value="employee.GenderId">
                <option value="">-- اختر الجنس --</option>
                @foreach (var item in genders)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-6 mb-3">
            <label>المسمى الوظيفي</label>
            <InputSelect class="form-control" @bind-Value="employee.JobId">
                <option value="">-- اختر الوظيفة --</option>
                @foreach (var item in jobs)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-6 mb-3">
            <label>المسمى الوظيفي الأصلي</label>
            <InputSelect class="form-control" @bind-Value="employee.OrgJobId">
                <option value="">-- اختر الوظيفة الأصلية --</option>
                @foreach (var item in jobs)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-6 mb-3">
            <label>المدرسة الأصلية</label>
            <InputText class="form-control" @bind-Value="employee.OrgSchool" />
        </div>
        <div class="col-md-6 mb-3">
            <label>التخصص</label>
            <InputSelect class="form-control" @bind-Value="employee.SpecializationId">
                <option value="">-- اختر التخصص --</option>
                @foreach (var item in specs)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </InputSelect>
        </div>
    </div>

    <button type="submit" class="btn btn-success">حفظ البيانات</button>
    <a class="btn btn-secondary" href="/employees">إلغاء</a>
</EditForm>

@code {
    [Parameter] public long Id { get; set; }
    private Employee employee = new();

    // قوائم الـ Lookups
    private List<LookupValue> genders = new();
    private List<LookupValue> jobs = new();
    private List<LookupValue> specs = new();

    protected override async Task OnInitializedAsync()
    {
        // جلب البيانات للقوائم المنسدلة (يجب التأكد من أسماء الـ Types في API)
        genders = await LookupValueApi.GetByValueType(LookupTypes.Gender);
        jobs = await LookupValueApi.GetByValueType(LookupTypes.Jobs);
        specs = await LookupValueApi.GetByValueType(LookupTypes.Specialization);

        if (Id != 0) employee = await EmployeeApi.GetById(Id);
    }

    private async Task HandleValidSubmit()
    {
        if (Id == 0) await EmployeeApi.Insert(employee);
        else await EmployeeApi.Update(employee);

        NavManager.NavigateTo(PagesUris.EmployeesPages.Manage);
    }
} *@