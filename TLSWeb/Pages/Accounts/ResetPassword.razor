                                            <div class="input-group">
                                                <InputText @bind-Value="SelfChange.ConfirmPassword"
                                                           type="@InputType("confirm")"
                                                           class="form-control" />
                                                <button type="button" class="btn btn-outline-secondary"
                                                        @onclick='() => ToggleShow("confirm")'>
                                                    <i class="bi @EyeIcon("confirm")"></i>
                                                </button>
                                            </div>
                                            <ValidationMessage For="@(() => SelfChange.ConfirmPassword)" class="text-danger small" />
                                        </div>

                                        <button type="submit" class="btn btn-primary w-100" disabled="@IsSavingSelf">
                                            @if (IsSavingSelf)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-floppy-fill me-1"></i>
                                            }
                                            حفظ كلمة المرور الجديدة
                                        </button>
                                    </EditForm>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            } *@

        </div>
    }
</div>


