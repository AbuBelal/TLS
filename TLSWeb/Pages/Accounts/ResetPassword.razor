@* ╔══════════════════════════════════════════════════════════════╗ *@
@* ║  TLSWeb/Pages/Accounts/ResetPassword.razor                   ║ *@
@* ║  صفحة إعادة ضبط كلمات المرور                                ║ *@
@* ║  — المدير: يعيد ضبط كلمة أي مستخدم                          ║ *@
@* ║  — المستخدم العادي: يغير كلمة مروره الخاصة                   ║ *@
@* ╚══════════════════════════════════════════════════════════════╝ *@

@* @page "/Accounts/ResetPassword" *@
@attribute [Route(PagesUris.Admin.ResetPassword)]
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = SharedLib.Fixed.Roles.Admin)]

<div class="container-fluid px-4" dir="rtl">

    @* ══ رأس الصفحة ══ *@
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <h3 class="mb-0">
            <i class="bi bi-shield-lock-fill me-2 text-primary"></i>
            @(IsAdmin ? "إدارة كلمات المرور" : "تغيير كلمة المرور")
        </h3>
        @if (IsAdmin)
        {
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fs-6">
                <i class="bi bi-people me-1"></i>
                <strong>@Users.Count</strong> مستخدم
            </span>
        }
    </div>

    @* ══ تحميل ══ *@
    @if (IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height:50vh">
            <div class="text-center">
                <div class="spinner-border text-primary" style="width:3rem;height:3rem" role="status"></div>
                <p class="mt-3 text-muted small">جاري التحميل...</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">

            @* ════════════════════════════════════════════════════ *@
            @* قسم المدير — قائمة المستخدمين + نموذج إعادة الضبط  *@
            @* ════════════════════════════════════════════════════ *@
            @if (IsAdmin)
            {
                @* ── قائمة المستخدمين ── *@
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-bottom py-3">
                            <div class="fw-semibold mb-2">
                                <i class="bi bi-people me-2 text-primary"></i>اختر مستخدماً
                            </div>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="bi bi-search text-muted"></i>
                                </span>
                                <input type="text"
                                       class="form-control border-start-0"
                                       placeholder="بحث بالاسم أو الإيميل..."
                                       @bind="SearchText"
                                       @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="card-body p-0" style="overflow-y:auto;max-height:500px">
                            @if (!FilteredUsers.Any())
                            {
                                <div class="text-center py-5 text-muted small">
                                    <i class="bi bi-person-x fs-3 d-block mb-2"></i>
                                    لا توجد نتائج
                                </div>
                            }
                            else
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var user in FilteredUsers)
                                    {
                                        var isSelected = SelectedUser?.Id == user?.Id;
                                        <li class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3 @(isSelected ? "bg-primary bg-opacity-10 border-start border-primary border-3" : "")"
                                            style="cursor:pointer"
                                            @onclick="() => SelectUser(user)">

                                            @* أفاتار بالحرف الأول *@
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white flex-shrink-0"
                                                 style="width:40px;height:40px;background:@(isSelected ? "#0d6efd" : "#6c757d");font-size:16px">
                                                @((user?.UserName ?? "?").Substring(0, 1).ToUpper())
                                            </div>

                                            <div class="flex-grow-1 min-w-0">
                                                <div class="fw-semibold small text-truncate">
                                                    @user?.UserName
                                                </div>
                                                <div class="text-muted" style="font-size:.75rem">
                                                    @user?.Email
                                                </div>
                                                @if (user?.Employee is not null)
                                                {
                                                    <div class="text-muted" style="font-size:.72rem">
                                                        <i class="bi bi-person-badge me-1"></i>@user.Employee.Name
                                                    </div>
                                                }
                                            </div>

                                            <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
                                                @foreach (var role in (user?.Roles ?? new()))
                                                {
                                                    <span class="badge rounded-pill @(role == SharedLib.Fixed.Roles.Admin ? "bg-danger" : role == SharedLib.Fixed.Roles.User ? "bg-primary" : "bg-secondary") bg-opacity-75"
                                                          style="font-size:.65rem">
                                                        @role
                                                    </span>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                </div>

                @* ── نموذج إعادة الضبط ── *@
                <div class="col-lg-7">
                    @if (SelectedUser is null)
                    {
                        <div class="card border-0 shadow-sm h-100 d-flex align-items-center justify-content-center"
                             style="min-height:300px">
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-arrow-right-circle fs-1 d-block mb-3 text-primary opacity-50"></i>
                                <p class="fw-semibold">اختر مستخدماً من القائمة</p>
                                <p class="small">لإعادة ضبط كلمة مروره</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card border-0 shadow-sm">

                            @* رأس البطاقة *@
                            <div class="card-header bg-white border-bottom py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width:44px;height:44px;background:#0d6efd;font-size:18px">
                                            @SelectedUser.UserName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold">@SelectedUser.UserName</div>
                                            <div class="text-muted small">@SelectedUser.Email</div>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSelection">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="card-body">

                                @* تحذير *@
                                <div class="alert alert-warning d-flex gap-2 py-2 small mb-4">
                                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                                    <span>
                                        ستُعاد كلمة مرور هذا المستخدم. سيحتاج لتسجيل الدخول بكلمة المرور الجديدة.
                                    </span>
                                </div>

                                <EditForm Model="@AdminReset" OnValidSubmit="HandleAdminReset">
                                    <DataAnnotationsValidator />

                                    @* كلمة المرور الجديدة *@
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold text-muted small">
                                            كلمة المرور الجديدة <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <InputText @bind-Value="AdminReset.NewPassword"
                                                       type="@InputType("anew")"
                                                       class="form-control"
                                                       placeholder="6 أحرف على الأقل" />
                                            <button type="button" class="btn btn-outline-secondary"
                                                    @onclick='() => ToggleShow("anew")'>
                                                <i class="bi @EyeIcon("anew")"></i>
                                            </button>
                                        </div>
                                        <ValidationMessage For="@(() => AdminReset.NewPassword)" class="text-danger small" />

                                        @* مؤشر القوة *@
                                        @{
                                            var (score, label, color) = PasswordStrength(AdminReset.NewPassword);
                                        }
                                        @if (score > 0)
                                        {
                                            <div class="mt-2">
                                                <div class="progress" style="height:5px;border-radius:3px">
                                                    <div class="progress-bar @color" style="width:@score%"></div>
                                                </div>
                                                <small class="text-muted">قوة كلمة المرور: <span class="fw-semibold">@label</span></small>
                                            </div>
                                        }
                                    </div>

                                    @* تأكيد كلمة المرور *@
                                    <div class="mb-4">
                                        <label class="form-label fw-semibold text-muted small">
                                            تأكيد كلمة المرور <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <InputText @bind-Value="AdminReset.ConfirmPassword"
                                                       type="@InputType("aconfirm")"
                                                       class="form-control"
                                                       placeholder="أعد كتابة كلمة المرور" />
                                            <button type="button" class="btn btn-outline-secondary"
                                                    @onclick='() => ToggleShow("aconfirm")'>
                                                <i class="bi @EyeIcon("aconfirm")"></i>
                                            </button>
                                        </div>
                                        @* مؤشر التطابق *@
                                        @if (!string.IsNullOrEmpty(AdminReset.ConfirmPassword))
                                        {
                                            @if (AdminReset.NewPassword == AdminReset.ConfirmPassword)
                                            {
                                                <small class="text-success">
                                                    <i class="bi bi-check-circle me-1"></i>كلمتا المرور متطابقتان
                                                </small>
                                            }
                                            else
                                            {
                                                <small class="text-danger">
                                                    <i class="bi bi-x-circle me-1"></i>كلمتا المرور غير متطابقتين
                                                </small>
                                            }
                                        }
                                        <ValidationMessage For="@(() => AdminReset.ConfirmPassword)" class="text-danger small d-block" />
                                    </div>

                                    <button type="submit"
                                            class="btn btn-danger w-100 py-2"
                                            disabled="@IsSavingAdmin">
                                        @if (IsSavingAdmin)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            <span>جاري إعادة الضبط...</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-arrow-repeat me-2"></i>
                                            <span>إعادة ضبط كلمة المرور</span>
                                        }
                                    </button>
                                </EditForm>
                            </div>
                        </div>
                    }
                </div>
            }

            @* ════════════════════════════════════════════════════ *@
            @* قسم المستخدم العادي — تغيير كلمة المرور الخاصة     *@
            @* ════════════════════════════════════════════════════ *@
            @if (!IsAdmin)
            {
                <div class="col-12 col-md-8 col-lg-6 mx-auto">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-bottom fw-semibold py-3">
                            <i class="bi bi-key me-2 text-primary"></i>تغيير كلمة المرور
                        </div>
                        <div class="card-body">

                            @* إرشادات *@
                            <div class="alert alert-primary bg-primary bg-opacity-10 border-0 small d-flex gap-2 mb-4">
                                <i class="bi bi-info-circle-fill text-primary flex-shrink-0 mt-1"></i>
                                <ul class="mb-0 ps-3">
                                    <li>يجب إدخال كلمة المرور الحالية للتحقق من هويتك</li>
                                    <li>كلمة المرور الجديدة: 6 أحرف على الأقل</li>
                                    <li>يُنصح باستخدام حروف كبيرة وصغيرة وأرقام ورموز</li>
                                </ul>
                            </div>

                            <EditForm Model="@SelfChange" OnValidSubmit="HandleSelfChange">
                                <DataAnnotationsValidator />

                                @* كلمة المرور الحالية *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted small">
                                        كلمة المرور الحالية <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <InputText @bind-Value="SelfChange.OldPassword"
                                                   type="@InputType("old")"
                                                   class="form-control"
                                                   placeholder="أدخل كلمة مرورك الحالية" />
                                        <button type="button" class="btn btn-outline-secondary"
                                                @onclick='() => ToggleShow("old")'>
                                            <i class="bi @EyeIcon("old")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => SelfChange.OldPassword)" class="text-danger small" />
                                </div>

                                <hr class="my-3" />

                                @* كلمة المرور الجديدة *@
                                <div class="mb-3">
                                    <label class="form-label fw-semibold text-muted small">
                                        كلمة المرور الجديدة <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <InputText @bind-Value="SelfChange.NewPassword"
                                                   type="@InputType("new")"
                                                   class="form-control"
                                                   placeholder="6 أحرف على الأقل" />
                                        <button type="button" class="btn btn-outline-secondary"
                                                @onclick='() => ToggleShow("new")'>
                                            <i class="bi @EyeIcon("new")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => SelfChange.NewPassword)" class="text-danger small" />

                                    @* مؤشر القوة *@
                                    @{
                                        var (score, label, color) = PasswordStrength(SelfChange.NewPassword);
                                    }
                                    @if (score > 0)
                                    {
                                        <div class="mt-2">
                                            <div class="progress" style="height:5px;border-radius:3px">
                                                <div class="progress-bar @color" style="width:@score%"></div>
                                            </div>
                                            <small class="text-muted">
                                                قوة كلمة المرور:
                                                <span class="fw-semibold @(color.Replace("bg-","text-"))">@label</span>
                                            </small>
                                        </div>
                                    }
                                </div>

                                @* تأكيد كلمة المرور *@
                                <div class="mb-4">
                                    <label class="form-label fw-semibold text-muted small">
                                        تأكيد كلمة المرور الجديدة <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <InputText @bind-Value="SelfChange.ConfirmPassword"
                                                   type="@InputType("confirm")"
                                                   class="form-control"
                                                   placeholder="أعد كتابة كلمة المرور الجديدة" />
                                        <button type="button" class="btn btn-outline-secondary"
                                                @onclick='() => ToggleShow("confirm")'>
                                            <i class="bi @EyeIcon("confirm")"></i>
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(SelfChange.ConfirmPassword))
                                    {
                                        @if (SelfChange.NewPassword == SelfChange.ConfirmPassword)
                                        {
                                            <small class="text-success">
                                                <i class="bi bi-check-circle me-1"></i>كلمتا المرور متطابقتان
                                            </small>
                                        }
                                        else
                                        {
                                            <small class="text-danger">
                                                <i class="bi bi-x-circle me-1"></i>كلمتا المرور غير متطابقتين
                                            </small>
                                        }
                                    }
                                    <ValidationMessage For="@(() => SelfChange.ConfirmPassword)" class="text-danger small d-block" />
                                </div>

                                <button type="submit"
                                        class="btn btn-primary w-100 py-2"
                                        disabled="@IsSavingSelf">
                                    @if (IsSavingSelf)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>جاري الحفظ...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-floppy-fill me-2"></i>
                                        <span>حفظ كلمة المرور الجديدة</span>
                                    }
                                </button>
                            </EditForm>
                        </div>
                    </div>
                </div>
            }

            @* ════════════════════════════════════════════════════ *@
            @* تغيير كلمة مرور المدير نفسه (ظاهر للمدير دائماً)   *@
            @* ════════════════════════════════════════════════════ *@
